<script>
    // Modern Navbar Scroll Logic
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('floatingNav');
        const container = nav.querySelector('.glass-panel');
        if (window.scrollY > 20) {
            nav.classList.add('py-2');
            nav.classList.remove('py-4');
            container.classList.add('shadow-2xl', 'scale-[0.98]', 'sm:scale-95');
        } else {
            nav.classList.add('py-4');
            nav.classList.remove('py-2');
            container.classList.remove('shadow-2xl', 'scale-[0.98]', 'sm:scale-95');
        }
    });

    function toggleMobileMenu() {
        const overlay = document.getElementById('mobileMenuOverlay');
        const menu = document.getElementById('mobileMenu');
        const body = document.body;
        
        if (overlay.classList.contains('hidden')) {
            overlay.classList.remove('hidden');
            setTimeout(() => menu.classList.remove('translate-x-full'), 10);
            body.style.overflow = 'hidden';
        } else {
            menu.classList.add('translate-x-full');
            setTimeout(() => overlay.classList.add('hidden'), 500);
            body.style.overflow = '';
        }
    }

    // Close mobile menu when clicking on links
    function closeMobileMenuOnLinkClick() {
        const menuLinks = document.querySelectorAll('#mobileMenu a');
        menuLinks.forEach(link => {
            link.addEventListener('click', () => {
                toggleMobileMenu();
            });
        });
    }
    
    // Make functions globally available
    window.toggleMobileMenu = toggleMobileMenu;
    
    // Initialize mobile menu
    document.addEventListener('DOMContentLoaded', function() {
        closeMobileMenuOnLinkClick();
    });
</script>

