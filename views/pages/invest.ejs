<!-- Core Philosophy Section -->
<section class="py-24 relative bg-white dark:bg-lux-midnight overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl lg:text-5xl font-display font-bold text-gray-900 dark:text-white mb-8 leading-tight">
                    Smart Wealth <br/><span class="text-emerald-500">Starts With Real Assets</span>
                </h2>
                <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
                    At DeepRealties, we don't just find properties; we identify strategic growth engines. Our data-driven approach minimizes risk while maximizing long-term wealth appreciation for our partners.
                </p>
                <div class="space-y-6">
                    <div class="flex items-start group">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mr-4 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Preservation of Capital</h3>
                            <p class="text-gray-600 dark:text-gray-400">Every investment undergoes a 28-point due diligence process to ensure title clarity and market safety.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="glass-panel p-8 rounded-3xl mt-12 bg-emerald-500 dark:bg-emerald-600">
                    <h3 class="text-2xl font-bold text-white mb-4">Diversified Portfolio</h3>
                    <p class="text-white/80 text-sm leading-relaxed">Spread your risk across residential, commercial, and agricultural sectors under one unified dashboard.</p>
                </div>
                <div class="glass-panel p-8 rounded-3xl bg-gray-50 dark:bg-white/5">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Strategic Yield</h3>
                    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">Focus on emerging corridors where appreciation potential is combined with immediate rental income.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Investment Sectors -->
<section class="py-24 bg-gray-50 dark:bg-black/40 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-display font-bold text-gray-900 dark:text-white mb-4">Investment Sectors</h2>
            <div class="w-20 h-1 bg-emerald-500 mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Residential -->
            <div class="glass-panel p-8 rounded-3xl hover:border-emerald-500/50 transition-all group overflow-hidden relative">
                <div class="absolute -bottom-10 -right-10 w-24 h-24 bg-emerald-500/5 group-hover:bg-emerald-500/10 rounded-full blur-2xl transition-all"></div>
                <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Residential</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Secure high-growth housing projects in premium urban corridors.</p>
            </div>
            <!-- Commercial -->
            <div class="glass-panel p-8 rounded-3xl hover:border-emerald-500/50 transition-all group overflow-hidden relative">
                <div class="absolute -bottom-10 -right-10 w-24 h-24 bg-emerald-500/5 group-hover:bg-emerald-500/10 rounded-full blur-2xl transition-all"></div>
                <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Commercial</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Invest in office spaces and retail hubs with long-term institutional leases.</p>
            </div>
            <!-- Industrial/Land -->
            <div class="glass-panel p-8 rounded-3xl hover:border-emerald-500/50 transition-all group overflow-hidden relative">
                <div class="absolute -bottom-10 -right-10 w-24 h-24 bg-emerald-500/5 group-hover:bg-emerald-500/10 rounded-full blur-2xl transition-all"></div>
                <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Industrial/Land</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Strategic land acquisitions near upcoming highways and industrial zones.</p>
            </div>
            <!-- Agricultural -->
            <div class="glass-panel p-8 rounded-3xl hover:border-emerald-500/50 transition-all group overflow-hidden relative">
                <div class="absolute -bottom-10 -right-10 w-24 h-24 bg-emerald-500/5 group-hover:bg-emerald-500/10 rounded-full blur-2xl transition-all"></div>
                <div class="w-14 h-14 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Agricultural</h3>
                <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">Managed farmland with sustainable return models and appreciation potential.</p>
            </div>
        </div>
    </div>
</section>

<!-- Investor CTA Section -->
<section class="py-24 bg-lux-midnight relative overflow-hidden">
    <!-- Background Accents -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-emerald-500/10 blur-[150px]"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-emerald-600/5 blur-[150px]"></div>

    <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-8">Ready to Scale Your Portfolio?</h2>
        <p class="text-xl text-white/60 mb-12">
            Register now to receive whitepapers and early access to off-market investment opportunities.
        </p>
        <button onclick="showInvestorForm()" class="px-10 py-5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-2xl font-bold text-lg transition-all shadow-2xl shadow-emerald-500/20">
            Register for Early Access
        </button>
    </div>
</section>

<!-- Investor Registration Modal -->
<div id="investorModal" class="fixed inset-0 z-50 overflow-y-auto hidden">
    <div class="fixed inset-0 bg-lux-midnight/90 backdrop-blur-sm transition-opacity" onclick="closeInvestorForm()"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative bg-white dark:bg-lux-midnight rounded-[2.5rem] shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden border border-white/10">
            <!-- Modal Header -->
            <div class="p-8 pb-0 flex items-center justify-between">
                <div>
                    <h2 class="text-3xl font-display font-bold text-gray-900 dark:text-white">Investor Onboarding</h2>
                    <p class="text-gray-500 text-sm mt-1">Tell us about your investment preferences</p>
                </div>
                <button onclick="closeInvestorForm()" class="p-2 text-gray-400 hover:text-white hover:bg-white/5 rounded-full transition-all">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <!-- Modal Body -->
            <div class="p-8 overflow-y-auto max-h-[70vh]">
                <form id="investorForm" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest">Full Name</label>
                            <input type="text" name="full_name" required placeholder="John Doe"
                                   class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest">Email Address</label>
                            <input type="email" name="email" required placeholder="john@example.com"
                                   class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest">Phone Number</label>
                            <input type="tel" name="phone" required placeholder="+91 98XXX XXXX"
                                   class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest">Budget (Optional)</label>
                            <input type="number" name="investment_budget" placeholder="₹"
                                   class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all">
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest">Investment Preference</label>
                        <select name="investment_type" class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all appearance-none">
                            <option value="">Select Sector</option>
                            <option value="residential">Residential Yield</option>
                            <option value="commercial">Commercial Lease</option>
                            <option value="land">Strategic Land</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest">Message / Requirements</label>
                        <textarea name="message" rows="4" placeholder="How can we help grow your wealth?"
                                  class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all"></textarea>
                    </div>

                    <button type="submit" 
                            class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-lg rounded-2xl transition-all shadow-xl shadow-emerald-500/20">
                        Submit Registration
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    window.showInvestorForm = function() {
        const modal = document.getElementById('investorModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    };
    
    window.closeInvestorForm = function() {
        const modal = document.getElementById('investorModal');
        modal.classList.add('hidden');
        document.body.style.overflow = '';
    };

    document.getElementById('investorForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const submitBtn = e.target.querySelector('button[type="submit"]');
        
        try {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="flex items-center justify-center"><svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Processing...</span>';

            const data = {
                full_name: formData.get('full_name'),
                email: formData.get('email'),
                phone: formData.get('phone'),
                subject: 'Investor Registration - ' + (formData.get('investment_type') || 'General'),
                message: \\\`Budget: ₹\\\${formData.get('investment_budget') || 'N/A'}\\\\nType: \\\${formData.get('investment_type')}\\\\nMessage: \\\${formData.get('message')}\\\`
            };

            const response = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                if (window.showSuccess) window.showSuccess('Registration successful! We will contact you soon.');
                else alert('Registration successful!');
                window.closeInvestorForm();
                e.target.reset();
            } else {
                throw new Error('Submission failed');
            }
        } catch (error) {
            if (window.showError) window.showError('An error occurred. Please try again.');
            else alert('An error occurred');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Submit Registration';
        }
    });
</script>
` }) %>
