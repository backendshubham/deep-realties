<%
  const hasDates = typeof blog !== 'undefined' && blog && (blog.published_at || blog.created_at);
%>
<%- include('../layouts/main', { content: `
<!-- Registration Canvas -->
<div class="min-h-screen relative flex items-center justify-center py-24 px-4 sm:px-6 lg:px-8 overflow-hidden bg-[#F8FAFC] dark:bg-lux-midnight transition-colors">
    <!-- Animated Orbs -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-emerald-500/10 dark:bg-emerald-500/5 blur-[150px] animate-pulse"></div>
        <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-emerald-500/10 dark:bg-emerald-900/10 blur-[150px] animate-pulse" style="animation-delay: 3s;"></div>
    </div>

    <div class="max-w-xl w-full relative z-10">
        <!-- Brand Header -->
        <div class="text-center mb-12">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-[0.4em] mb-8 backdrop-blur-md">
                JOIN THE ELITE CIRCLE
            </span>
            <h1 class="text-4xl md:text-5xl font-display font-bold text-lux-midnight dark:text-white mb-4 tracking-tight">
                Create Your <span class="text-emerald-600 dark:text-emerald-400 italic font-serif">Legacy</span>
            </h1>
            <p class="text-gray-500 dark:text-white/40 text-sm font-medium tracking-wide">
                Already a member? 
                <a href="/login" class="text-emerald-600 dark:text-emerald-400 font-bold hover:text-emerald-500 dark:hover:text-emerald-300 transition-colors underline underline-offset-4 decoration-emerald-500/30">Sign In to Portfolio</a>
            </p>
        </div>

        <!-- Stepper Indicator -->
        <div class="flex items-center justify-center gap-6 mb-12">
            <div class="flex flex-col items-center gap-3">
                <div id="dot1" class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_15px_rgba(16,185,129,0.5)] transition-all duration-500"></div>
                <span class="text-[9px] uppercase tracking-[0.3em] font-bold text-emerald-500">Verification</span>
            </div>
            <div class="h-px w-16 bg-gray-200 dark:bg-white/10"></div>
            <div class="flex flex-col items-center gap-3">
                <div id="dot2" class="w-2.5 h-2.5 rounded-full bg-gray-200 dark:bg-white/10 transition-all duration-500"></div>
                <span class="text-[9px] uppercase tracking-[0.3em] font-bold text-gray-400 dark:text-white/20">Profile</span>
            </div>
        </div>

        <!-- Glassmorphic Card -->
        <div class="glass-panel p-8 sm:p-12 rounded-[3.5rem] border-gray-200 dark:border-white/10 shadow-2xl backdrop-blur-2xl bg-white/80 dark:bg-white/5 overflow-hidden">
            <form id="registerForm" class="space-y-8">
                <!-- STEP 1: Verification -->
                <div id="step1">
                    <div class="space-y-8">
                        <div class="group">
                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Email Address</label>
                            <input type="email" id="email" name="email" required 
                                   class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-lux-midnight dark:text-white placeholder-gray-400 dark:placeholder-white/10 focus:border-emerald-500/50 outline-none transition-all"
                                   placeholder="curator@deeprealties.com">
                        </div>

                        <button type="button" id="otpBtn" onclick="sendOTP()" 
                                class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs uppercase tracking-widest rounded-2xl shadow-xl shadow-emerald-500/20 transition-all active:scale-[0.98] flex items-center justify-center gap-3 group">
                            <span>Send Access Code</span>
                            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </button>

                        <div id="otpSection" class="hidden animate-[fadeInUp_0.5s_ease] pt-8 border-t border-gray-100 dark:border-white/5 italic">
                            <p class="text-center text-[10px] text-gray-500 dark:text-white/40 uppercase tracking-widest mb-6">Enter the 6-digit verification code</p>
                            <div class="flex gap-4">
                                <input id="otp" type="text" maxlength="6" 
                                       class="flex-1 px-6 py-4 text-center text-2xl tracking-[0.5em] font-mono rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-emerald-600 dark:text-emerald-400 outline-none focus:border-emerald-500/50"
                                       placeholder="••••••">
                                <button type="button" onclick="verifyOTP()" class="px-8 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/20 text-lux-midnight dark:text-white font-bold rounded-2xl transition-all">Verify</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- STEP 2: Profile (Hidden) -->
                <div id="step2" class="hidden animate-[fadeInUp_0.5s_ease] space-y-8">
                    <div class="flex items-center space-x-4 p-5 bg-emerald-500/5 border border-emerald-500/20 rounded-2xl mb-4">
                        <div class="w-10 h-10 rounded-full bg-emerald-500 flex items-center justify-center text-white">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <div class="overflow-hidden">
                            <p id="verifiedEmail" class="text-sm font-bold text-lux-midnight dark:text-white truncate"></p>
                            <p class="text-[9px] text-emerald-600 dark:text-emerald-500 font-bold uppercase tracking-widest">Ownership Verified</p>
                        </div>
                    </div>

                    <div class="grid md:grid-cols-2 gap-6">
                        <div class="group">
                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Full Name</label>
                            <input type="text" name="full_name" required class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-lux-midnight dark:text-white outline-none focus:border-emerald-500/50">
                        </div>
                        <div class="group">
                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Phone (+91)</label>
                            <input type="tel" name="phone" id="phone" maxlength="10" required class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-lux-midnight dark:text-white outline-none focus:border-emerald-500/50">
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Account Role</label>
                        <div class="grid grid-cols-2 gap-4">
                            <label class="role-btn relative flex flex-col items-center justify-center p-6 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl cursor-pointer hover:bg-emerald-500/5 transition-all group-role">
                                <input type="radio" name="role" value="buyer" required class="hidden opacity-0">
                                <span class="text-2xl mb-2 grayscale group-hover:grayscale-0 transition-all">🏠</span>
                                <span class="text-[10px] font-bold text-gray-400 dark:text-white/40 uppercase tracking-widest group-hover:text-emerald-600 dark:group-hover:text-emerald-500">Buyer</span>
                                <div class="role-check absolute top-2 right-2 hidden"><svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg></div>
                            </label>
                            <label class="role-btn relative flex flex-col items-center justify-center p-6 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl cursor-pointer hover:bg-emerald-500/5 transition-all group-role">
                                <input type="radio" name="role" value="seller" required class="hidden opacity-0">
                                <span class="text-2xl mb-2 grayscale group-hover:grayscale-0 transition-all">💰</span>
                                <span class="text-[10px] font-bold text-gray-400 dark:text-white/40 uppercase tracking-widest group-hover:text-emerald-600 dark:group-hover:text-emerald-500">Seller</span>
                                <div class="role-check absolute top-2 right-2 hidden"><svg class="w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg></div>
                            </label>
                        </div>
                    </div>

                    <div class="group">
                        <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Create Password</label>
                        <input type="password" name="password" required class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-lux-midnight dark:text-white outline-none focus:border-emerald-500/50">
                    </div>

                    <div class="flex items-center space-x-3 px-1">
                        <input type="checkbox" id="terms" required class="w-4 h-4 rounded border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 text-emerald-500 focus:ring-emerald-500/20">
                        <label for="terms" class="text-[10px] text-gray-500 dark:text-white/40 uppercase tracking-widest font-bold">Accept Premium Protocol</label>
                    </div>

                    <button type="submit" id="submitBtn" class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-sm uppercase tracking-[0.2em] rounded-2xl shadow-2xl shadow-emerald-500/20 transition-all active:scale-[0.98] flex items-center justify-center gap-3">
                        <span id="submitText">Initialize Account</span>
                        <span id="submitSpinner" class="hidden spinner border-t-white !w-4 !h-4"></span>
                    </button>
                </div>
            </form>
        </div>
        
        <div class="mt-12 text-center">
            <p class="text-[10px] font-bold text-gray-300 dark:text-white/20 uppercase tracking-[0.5em]">DeepRealties Genesis Protocol</p>
        </div>
    </div>
</div>

<script>
    async function sendOTP() {
        const email = document.getElementById('email');
        const btn = document.getElementById('otpBtn');
        const section = document.getElementById('otpSection');

        if(!email.value) return;
        
        btn.disabled = true;
        btn.querySelector('span').textContent = 'Generating...';

        try {
            const res = await fetch('/api/auth/send-verification-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: email.value })
            });
            if(res.ok) {
                window.showSuccess && window.showSuccess('Access code sent.');
                section.classList.remove('hidden');
                btn.querySelector('span').textContent = 'Resend Code';
            }
        } catch(e) { console.error(e); }
        finally { btn.disabled = false; }
    }

    async function verifyOTP() {
        const email = document.getElementById('email').value;
        const otp = document.getElementById('otp').value;
        
        try {
            const res = await fetch('/api/auth/verify-email-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, otp })
            });

            if(res.ok) {
                document.getElementById('step1').classList.add('hidden');
                document.getElementById('step2').classList.remove('hidden');
                document.getElementById('dot1').classList.replace('bg-emerald-500', 'bg-white/10');
                document.getElementById('dot1').classList.remove('shadow-[0_0_15px_rgba(16,185,129,0.5)]');
                document.getElementById('dot2').classList.replace('bg-white/10', 'bg-emerald-500');
                document.getElementById('dot2').classList.add('shadow-[0_0_15px_rgba(16,185,129,0.5)]');
                document.getElementById('verifiedEmail').textContent = email;
            } else {
                window.showError && window.showError('Invalid code.');
            }
        } catch(e) { console.error(e); }
    }

    document.getElementById('registerForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const text = document.getElementById('submitText');
        const spin = document.getElementById('submitSpinner');
        
        btn.disabled = true;
        text.textContent = 'Initializing...';
        spin.classList.remove('hidden');

        try {
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);
            data.email = document.getElementById('email').value;
            data.phone = '+91' + data.phone.replace(/\\\\D/g, '');

            const res = await fetch('/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if(res.ok) {
                localStorage.setItem('token', result.token);
                window.location.href = '/dashboard';
            } else {
                throw new Error(result.error);
            }
        } catch(e) {
            window.showError && window.showError(e.message);
            btn.disabled = false;
            text.textContent = 'Initialize Account';
            spin.classList.add('hidden');
        }
    });

    document.querySelectorAll('.role-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.role-btn').forEach(b => {
                b.classList.remove('border-emerald-500/50', 'bg-emerald-500/5');
                b.querySelector('.role-check').classList.add('hidden');
                b.querySelector('span:last-of-type').classList.replace('text-emerald-500', 'text-white/40');
            });
            btn.classList.add('border-emerald-500/50', 'bg-emerald-500/5');
            btn.querySelector('.role-check').classList.remove('hidden');
            btn.querySelector('span:last-of-type').classList.replace('text-white/40', 'text-emerald-500');
        });
    });
</script>
` }) %>
