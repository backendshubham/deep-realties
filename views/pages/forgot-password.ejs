<%- include('../layouts/main', { content: `
<!-- Authentication Canvas -->
<div class="min-h-screen relative flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8 overflow-hidden bg-[#F8FAFC] dark:bg-lux-midnight transition-colors">
    <!-- Animated Cinematic Background -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-emerald-500/10 dark:bg-emerald-500/10 blur-[150px] animate-pulse"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-emerald-500/10 dark:bg-emerald-900/10 blur-[150px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="max-w-md w-full relative z-10">
        <!-- Brand Header -->
        <div class="text-center mb-12">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-[0.4em] mb-8 backdrop-blur-md">
                SECURITY PROTOCOL
            </span>
            <h1 class="text-4xl md:text-5xl font-display font-bold text-lux-midnight dark:text-white mb-4 tracking-tight">
                Recover <span class="text-emerald-600 dark:text-emerald-400 italic font-serif">Access</span>
            </h1>
            <p class="text-gray-500 dark:text-white/40 text-sm font-medium tracking-wide">
                Remember your credentials? 
                <a href="/login" class="text-emerald-600 dark:text-emerald-400 font-bold hover:text-emerald-500 dark:hover:text-emerald-300 transition-colors underline underline-offset-4 decoration-emerald-500/30">Return to Login</a>
            </p>
        </div>

        <!-- Glassmorphic Card -->
        <div class="glass-panel p-10 sm:p-12 rounded-[3.5rem] border-gray-200 dark:border-white/10 shadow-2xl relative overflow-hidden backdrop-blur-2xl bg-white/80 dark:bg-white/5">
            <div id="feedbackArea" class="hidden mb-8 p-5 rounded-2xl text-xs font-bold flex items-center gap-3">
                <span id="feedbackText"></span>
            </div>

            <form id="forgotForm" class="space-y-10">
                <div class="group">
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Registered Email</label>
                    <input type="email" id="email" name="email" required 
                           class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-lux-midnight dark:text-white placeholder-gray-400 dark:placeholder-white/20 focus:border-emerald-500/50 outline-none transition-all"
                           placeholder="curator@deeprealties.com">
                </div>

                <div id="otpSection" class="hidden animate-[fadeInUp_0.5s_ease] pt-8 border-t border-gray-100 dark:border-white/5 italic">
                    <p class="text-center text-[10px] text-gray-500 dark:text-white/40 uppercase tracking-widest mb-6">Enter the 6-digit recovery code</p>
                    <div class="flex gap-4">
                        <input id="otp" type="text" maxlength="6" 
                               class="flex-1 px-6 py-4 text-center text-2xl tracking-[0.5em] font-mono rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-emerald-600 dark:text-emerald-400 outline-none focus:border-emerald-500/50"
                               placeholder="••••••">
                    </div>
                </div>

                <button type="submit" id="submitBtn" class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-sm uppercase tracking-[0.2em] rounded-2xl shadow-2xl shadow-emerald-500/20 transition-all active:scale-[0.98] flex items-center justify-center gap-3">
                    <span id="submitText">Send Recovery Link</span>
                    <span id="submitSpinner" class="hidden spinner border-t-white !w-4 !h-4"></span>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    let step = 1;
    document.getElementById('forgotForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const text = document.getElementById('submitText');
        const spin = document.getElementById('submitSpinner');
        const fb = document.getElementById('feedbackArea');
        const fbText = document.getElementById('feedbackText');

        if (step === 2) {
            const otp = document.getElementById('otp').value;
            const email = document.getElementById('email').value;
            if (otp.length === 6) {
                window.location.href = \\\`/reset-password?email=\\\${encodeURIComponent(email)}&otp=\\\${otp}\\\`;
            }
            return;
        }

        btn.disabled = true;
        text.textContent = 'Processing...';
        spin.classList.remove('hidden');

        try {
            const email = document.getElementById('email').value;
            const res = await fetch('/api/auth/send-verification-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });
            const result = await res.json();

            if (res.ok) {
                fb.className = 'mb-8 p-5 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-2xl text-xs font-bold flex items-center gap-3';
                fbText.textContent = 'Recovery code dispatched to your inbox.';
                fb.classList.remove('hidden');
                document.getElementById('otpSection').classList.remove('hidden');
                text.textContent = 'Verify & Reset';
                step = 2;
            } else {
                throw new Error(result.error);
            }
        } catch (e) {
            fb.className = 'mb-8 p-5 bg-red-500/10 border border-red-500/20 text-red-400 rounded-2xl text-xs font-bold flex items-center gap-3';
            fbText.textContent = e.message || 'Recovery Failed';
            fb.classList.remove('hidden');
        } finally {
            btn.disabled = false;
            spin.classList.add('hidden');
        }
    });
</script>
` }) %>
