<%- include('../../layouts/main', { content: `
<div class="min-h-screen py-12 bg-[#F8FAFC] dark:bg-lux-midnight transition-colors duration-500">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-6 slide-up">
            <div>
                <a href="/admin/blogs" class="inline-flex items-center text-xs font-bold text-emerald-600 uppercase tracking-widest hover:text-emerald-500 transition-colors mb-4 group">
                    <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Back to Collection
                </a>
                <h1 class="text-4xl font-display font-bold text-lux-midnight dark:text-white tracking-tight">Edit <span class="text-emerald-600 italic font-serif">Masterpiece</span></h1>
                <p class="text-gray-500 dark:text-white/40 text-sm mt-2">Craft a high-end real estate story for your audience.</p>
            </div>
            
            <div class="flex items-center gap-4">
                <button type="button" onclick="window.location.href='/admin/blogs'" class="px-6 py-3 rounded-xl border border-gray-200 dark:border-white/10 text-gray-600 dark:text-white/60 text-xs font-bold uppercase tracking-widest hover:bg-gray-50 dark:hover:bg-white/5 transition-all">
                    Discard
                </button>
                <button type="submit" form="blogForm" id="publishBtn" class="px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl text-xs font-bold uppercase tracking-widest shadow-xl shadow-emerald-600/20 transition-all hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-3">
                    <span>Update Blog</span>
                    <div id="loader" class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                </button>
            </div>
        </div>

        <form id="blogForm" class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-20">
            <!-- Main Content Area -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Title & Slug Panel -->
                <div class="glass-panel p-8 sm:p-10 rounded-[2.5rem] border-gray-200 dark:border-white/10 shadow-xl bg-white/80 dark:bg-white/5 backdrop-blur-xl">
                    <div class="space-y-6">
                        <div class="group">
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-[0.2em] mb-3 ml-1">Article Title</label>
                            <input type="text" id="title" required
                                   class="w-full px-6 py-4 rounded-2xl bg-gray-50/50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-xl font-bold text-lux-midnight dark:text-white placeholder-gray-300 dark:placeholder-white/10 focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/5 transition-all outline-none"
                                   placeholder="The Art of Luxury Living in Indore">
                        </div>

                        <div class="group">
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-[0.2em] mb-3 ml-1">URL Extension (Slug)</label>
                            <div class="relative">
                                <span class="absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 dark:text-white/20 text-xs font-mono">deeprealties.in/blogs/</span>
                                <input type="text" id="slug"
                                       class="w-full pl-[11.5rem] pr-6 py-4 rounded-2xl bg-gray-50/50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-xs font-mono text-emerald-600 dark:text-emerald-400 placeholder-gray-300 dark:placeholder-white/10 focus:border-emerald-500/50 focus:ring-4 focus:ring-emerald-500/5 transition-all outline-none"
                                       placeholder="luxury-living-indore">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Rich Text Editor Panel -->
                <div class="glass-panel p-8 sm:p-10 rounded-[2.5rem] border-gray-200 dark:border-white/10 shadow-xl bg-white/80 dark:bg-white/5 backdrop-blur-xl">
                    <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-[0.2em] mb-6 ml-1">Content Editor</label>
                    
                    <!-- Quill Container -->
                    <div id="editor-wrapper" class="rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50/30 dark:bg-white/5 overflow-hidden">
                        <div id="editor" style="height: 500px;" class="text-lux-midnight dark:text-white"></div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Controls -->
            <div class="space-y-8">
                <!-- Visuals Panel -->
                <div class="glass-panel p-8 rounded-[2.5rem] border-gray-200 dark:border-white/10 shadow-xl bg-white/80 dark:bg-white/5 backdrop-blur-xl">
                    <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-[0.2em] mb-6 ml-1 text-center">Featured Imagery</label>
                    <div id="imagePreview" class="relative aspect-video rounded-2xl bg-gray-100 dark:bg-white/5 border border-dashed border-gray-300 dark:border-white/10 overflow-hidden flex items-center justify-center group mb-6 transition-all hover:border-emerald-500/50">
                        <img id="previewImg" src="/favicon-32x32.png" class="hidden w-full h-full object-cover">
                        <div id="placeholder" class="text-center p-6">
                            <svg class="w-8 h-8 mx-auto text-gray-400 dark:text-white/20 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            <p class="text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-widest">Awaiting Visual</p>
                        </div>
                    </div>
                    
                    <div class="group">
                        <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-widest mb-3 ml-1">Image URL</label>
                        <input type="url" id="featuredImageUrl"
                               class="w-full px-5 py-3 rounded-xl bg-gray-50/50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-xs text-lux-midnight dark:text-white placeholder-gray-300 dark:placeholder-white/10 focus:border-emerald-500/50 transition-all outline-none"
                               placeholder="https://images.unsplash.com/...">
                    </div>
                </div>

                <!-- SEO Architecture -->
                <div class="glass-panel p-8 rounded-[2.5rem] border-gray-200 dark:border-white/10 shadow-xl bg-white/80 dark:bg-white/5 backdrop-blur-xl">
                    <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-[0.2em] mb-6 ml-1 text-center">Search Architecture</label>
                    
                    <div class="space-y-6">
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-widest mb-3 ml-1">Meta Title</label>
                            <input type="text" id="seoTitle" maxlength="60"
                                   class="w-full px-5 py-3 rounded-xl bg-gray-50/50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-xs text-lux-midnight dark:text-white focus:border-emerald-500/50 outline-none transition-all">
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-widest mb-3 ml-1">Meta Description</label>
                            <textarea id="seoDescription" rows="3" maxlength="160"
                                      class="w-full px-5 py-3 rounded-xl bg-gray-50/50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-xs text-lux-midnight dark:text-white focus:border-emerald-500/50 outline-none transition-all"></textarea>
                        </div>
                        
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-widest mb-3 ml-1">Keywords</label>
                            <input type="text" id="seoKeywords" placeholder="indore, property, luxury"
                                   class="w-full px-5 py-3 rounded-xl bg-gray-50/50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-xs text-lux-midnight dark:text-white focus:border-emerald-500/50 outline-none transition-all">
                        </div>
                    </div>
                </div>
                
                <!-- Status Panel -->
                <div class="glass-panel p-8 rounded-[2.5rem] border-gray-200 dark:border-white/10 shadow-xl bg-white/80 dark:bg-white/5 backdrop-blur-xl">
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] font-bold text-gray-400 dark:text-white/20 uppercase tracking-widest">Publish Status</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="isPublished" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none dark:bg-white/10 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-emerald-600"></div>
                        </label>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Quill Styles & Scripts -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<style>
    /* Quill Luxury Customization */
    .ql-toolbar.ql-snow {
        border: none !important;
        border-bottom: 1px solid rgba(0,0,0,0.05) !important;
        padding: 1rem !important;
        background: rgba(255,255,255,0.5);
    }
    .dark .ql-toolbar.ql-snow {
        border-bottom: 1px solid rgba(255,255,255,0.05) !important;
        background: rgba(255,255,255,0.02);
    }
    .ql-container.ql-snow {
        border: none !important;
        font-family: 'Outfit', sans-serif !important;
        font-size: 1rem !important;
    }
    .ql-editor {
        padding: 2rem !important;
    }
    .ql-editor.ql-blank::before {
        color: rgba(156, 163, 175, 0.5) !important;
        font-style: italic !important;
    }
    .dark .ql-editor.ql-blank::before {
        color: rgba(255, 255, 255, 0.2) !important;
    }
    .ql-snow .ql-stroke { stroke: #6b7280 !important; }
    .dark .ql-snow .ql-stroke { stroke: rgba(255,255,255,0.4) !important; }
    .ql-snow .ql-fill { fill: #6b7280 !important; }
    .dark .ql-snow .ql-fill { fill: rgba(255,255,255,0.4) !important; }
</style>

<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<script>
    const blogId = '<%= typeof blogId !== "undefined" ? blogId : "" %>';

    document.addEventListener('DOMContentLoaded', async function() {
        // Initialize Quill with Luxury Theme
        const quill = new Quill('#editor', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    ['blockquote', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'image'],
                    ['clean']
                ]
            },
            placeholder: 'Begin your narrative here...'
        });

        const titleInput = document.getElementById('title');
        const slugInput = document.getElementById('slug');
        const imgInput = document.getElementById('featuredImageUrl');
        const previewImg = document.getElementById('previewImg');
        const placeholder = document.getElementById('placeholder');

        // Live Slug Generation
        titleInput.addEventListener('input', () => {
            if (!slugInput.dataset.manual) {
                slugInput.value = titleInput.value
                    .toLowerCase()
                    .trim()
                    .replace(/[^a-z0-9]+/g, '-')
                    .replace(/^-+|-+$/g, '');
            }
        });

        slugInput.addEventListener('input', () => {
            slugInput.dataset.manual = true;
        });

        // Live Image Preview
        imgInput.addEventListener('input', () => {
            const val = imgInput.value.trim();
            if (val) {
                previewImg.src = val;
                previewImg.classList.remove('hidden');
                placeholder.classList.add('hidden');
            } else {
                previewImg.classList.add('hidden');
                placeholder.classList.remove('hidden');
            }
        });

        const triggerImagePreview = () => imgInput.dispatchEvent(new Event('input'));

        // Load existing data
        if (blogId) {
            try {
                const token = localStorage.getItem('token');
                const res = await fetch('/api/blogs/admin/list-all', {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                const data = await res.json();
                const blog = (data.blogs || []).find(b => b.id == blogId);
                
                if (blog) {
                    titleInput.value = blog.title || '';
                    slugInput.value = blog.slug || '';
                    if (blog.slug) slugInput.dataset.manual = true;
                    
                    document.getElementById('seoTitle').value = blog.seo_title || '';
                    document.getElementById('seoDescription').value = blog.seo_description || blog.excerpt || '';
                    document.getElementById('seoKeywords').value = blog.seo_keywords || '';
                    
                    imgInput.value = blog.featured_image_url || '';
                    triggerImagePreview();
                    
                    document.getElementById('isPublished').checked = !!blog.is_published;
                    
                    if (blog.content) {
                        quill.clipboard.dangerouslyPasteHTML(blog.content);
                    }
                }
            } catch (err) {
                console.error('Failed to load blog:', err);
                if (window.showError) window.showError('Failed to load blog details.');
            }
        }

        // Form Submission
        document.getElementById('blogForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const btn = document.getElementById('publishBtn');
            const loader = document.getElementById('loader');
            
            btn.disabled = true;
            loader.classList.remove('hidden');

            const payload = {
                title: titleInput.value,
                slug: slugInput.value,
                excerpt: document.getElementById('seoDescription').value.substring(0, 150),
                content: quill.root.innerHTML,
                featuredImageUrl: imgInput.value,
                seoTitle: document.getElementById('seoTitle').value,
                seoDescription: document.getElementById('seoDescription').value,
                seoKeywords: document.getElementById('seoKeywords').value,
                isPublished: document.getElementById('isPublished').checked
            };

            try {
                const token = localStorage.getItem('token');
                const res = await fetch('/api/blogs/' + blogId, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();

                if (res.ok) {
                    if (window.showSuccess) window.showSuccess('Article Updated Successfully');
                    else alert('Blog updated successfully');
                    
                    setTimeout(() => {
                        window.location.href = '/admin/blogs';
                    }, 1500);
                } else {
                    throw new Error(result.error || 'Identity Verification Failed');
                }
            } catch (err) {
                console.error(err);
                if (window.showError) window.showError(err.message);
                else alert(err.message);
                btn.disabled = false;
                loader.classList.add('hidden');
            }
        });
    });
</script>
` }) %>
