<%- include('../../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative bg-gradient-to-b from-blue-50 via-blue-50/50 to-white dark:from-gray-900 dark:via-gray-900 dark:to-gray-900 py-12 sm:py-16 lg:py-20 overflow-hidden">
    <!-- Decorative Background Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-20 left-10 w-64 sm:w-96 h-64 sm:h-96 bg-blue-100 dark:bg-blue-900/10 rounded-full blur-3xl opacity-40"></div>
        <div class="absolute bottom-20 right-20 w-56 sm:w-80 h-56 sm:h-80 bg-blue-50 dark:bg-blue-900/20 rounded-full blur-3xl opacity-30"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <span class="inline-block px-3 sm:px-4 py-1.5 sm:py-2 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-4 sm:mb-6 text-xs sm:text-sm font-semibold border border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300">
            Admin Property Management
        </span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-3 sm:mb-4 px-2">
            <span class="text-gray-900 dark:text-white">Edit Property</span>
        </h1>
        <p class="text-base sm:text-lg lg:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto px-4">
            Update property details, images, and pricing for listing <span class="font-mono text-emerald-500">#${propertyId.substring(0, 8).toUpperCase()}</span>
        </p>
    </div>
</section>

<!-- Form Section -->
<section class="py-8 sm:py-12 lg:py-16 bg-gradient-to-b from-white via-blue-50/20 to-white dark:from-gray-900 dark:via-gray-900 dark:to-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Success Message -->
        <div id="successMessage" class="hidden bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-xl p-8 mb-6 shadow-sm">
            <h2 class="text-2xl font-bold text-emerald-700 dark:text-emerald-400 mb-3">Property Updated Successfully!</h2>
            <p class="text-emerald-600 dark:text-emerald-300 mb-6 text-base leading-relaxed">
                Changes have been saved and are now live on the platform.
            </p>
            <div class="flex flex-wrap gap-4">
                <a href="/admin/properties" class="px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 dark:bg-emerald-500 dark:hover:bg-emerald-600 text-white rounded-lg font-semibold transition-colors shadow-sm hover:shadow-md">
                    Back to Property List
                </a>
                <a href="/properties/${propertyId}" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white rounded-lg font-semibold transition-colors shadow-sm hover:shadow-md">
                    View Live Page
                </a>
            </div>
        </div>
        
        <div id="loadingState" class="flex flex-col items-center justify-center py-20 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700">
            <div class="inline-loader-spinner mb-4"></div>
            <p class="text-gray-500 dark:text-gray-400">Fetching property archives...</p>
        </div>
        
        <div id="editFormContainer" class="hidden bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-8 border border-gray-200 dark:border-gray-700">
            <form id="editForm" class="space-y-6">
                <!-- Property Type Selection -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">
                        Property Type <span class="text-red-500">*</span>
                    </label>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                        <label class="flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-lg cursor-pointer hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors">
                            <input type="radio" name="property_type" value="plot" required class="mr-2">
                            <span class="text-sm">Plot</span>
                        </label>
                        <label class="flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-lg cursor-pointer hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors">
                            <input type="radio" name="property_type" value="flat" required class="mr-2">
                            <span class="text-sm">Flat</span>
                        </label>
                        <label class="flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-lg cursor-pointer hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors">
                            <input type="radio" name="property_type" value="house" required class="mr-2">
                            <span class="text-sm">House</span>
                        </label>
                        <label class="flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-lg cursor-pointer hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors">
                            <input type="radio" name="property_type" value="farmland" required class="mr-2">
                            <span class="text-sm">Farm Land</span>
                        </label>
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Property Title <span class="text-red-500">*</span>
                    </label>
                    <input type="text" name="title" required placeholder="Property Title"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Description <span class="text-red-500">*</span>
                    </label>
                    <textarea name="description" rows="4" required placeholder="Describe property..."
                              class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500"></textarea>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Locality <span class="text-red-500">*</span>
                        </label>
                        <input type="text" name="locality" required placeholder="Area / Locality"
                               class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            City <span class="text-red-500">*</span>
                        </label>
                        <input type="text" name="city" required placeholder="City"
                               class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                    </div>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        State <span class="text-red-500">*</span>
                    </label>
                    <input type="text" name="state" required placeholder="State"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div id="priceFieldContainer">
                        <label id="priceLabel" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Price (₹) <span class="text-red-500">*</span>
                        </label>
                        <input type="number" name="price" id="priceInput" placeholder="Property Price" min="0" step="0.01"
                               class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                    </div>
                    <div id="areaFieldContainer">
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Area (sqft) <span class="text-red-500">*</span>
                        </label>
                        <input type="number" name="area_sqft" id="areaInput" placeholder="Area in sqft" min="0" step="0.01"
                               class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500">
                    </div>
                </div>

                <div id="plotFields" class="hidden grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Length (ft)</label>
                        <input type="number" name="plot_length" id="plot_length" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Width (ft)</label>
                        <input type="number" name="plot_width" id="plot_width" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Total Area</label>
                        <input type="number" name="plot_total_area" id="plot_total_area" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                </div>

                <div id="farmlandFields" class="hidden grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Bigha</label>
                        <input type="number" name="farmland_bigha" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Acre</label>
                        <input type="number" name="farmland_acre" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Price/Bigha</label>
                        <input type="number" name="price_per_bigha" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                </div>

                <div id="otherPropertyFields" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Bedrooms</label>
                        <input type="number" name="bedrooms" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Bathrooms</label>
                        <input type="number" name="bathrooms" class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700">
                    </div>
                </div>

                <div id="imagesSection" class="border-t border-gray-200 dark:border-gray-700 pt-6">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">Property Images (Max 5)</label>
                    <div id="imageGrid" class="flex flex-wrap gap-4 mb-4">
                        <!-- Existing and New Previews -->
                    </div>
                    <div id="dropZone" class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-xl p-6 text-center cursor-pointer hover:border-emerald-500 transition-all">
                        <input type="file" id="imageInput" multiple accept="image/*" class="hidden">
                        <p class="text-gray-500 dark:text-gray-400">Click or drag images to add more</p>
                    </div>
                </div>

                <div class="pt-6">
                    <button type="submit" class="w-full py-4 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-600/20">
                        Update Property Archive
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    const propertyId = '${propertyId}';
    let selectedFiles = [];
    let existingImages = [];

    document.addEventListener('DOMContentLoaded', async () => {
        const token = localStorage.getItem('token');
        if (!token) { window.location.href = '/login'; return; }

        await loadPropertyData();
        setupEventListeners();
    });

    async function loadPropertyData() {
        try {
            const res = await fetch('/api/properties/' + propertyId);
            if (!res.ok) throw new Error('Property not found');
            const data = await res.json();
            const p = data.property;

            // Fill Form
            const form = document.getElementById('editForm');
            form.title.value = p.title;
            form.description.value = p.description;
            form.locality.value = p.locality;
            form.city.value = p.city;
            form.state.value = p.state;
            form.price.value = p.price;
            form.area_sqft.value = p.area_sqft;
            
            if (p.property_type) {
                const radio = form.querySelector('input[name="property_type"][value="' + p.property_type + '"]');
                if (radio) {
                    radio.checked = true;
                    togglePropertyFields(p.property_type);
                }
            }

            // Specific fields
            if (p.plot_length) form.plot_length.value = p.plot_length;
            if (p.plot_width) form.plot_width.value = p.plot_width;
            if (p.plot_total_area) form.plot_total_area.value = p.plot_total_area;
            if (p.farmland_bigha) form.farmland_bigha.value = p.farmland_bigha;
            if (p.farmland_acre) form.farmland_acre.value = p.farmland_acre;
            if (p.price_per_bigha) form.price_per_bigha.value = p.price_per_bigha;
            if (p.bedrooms) form.bedrooms.value = p.bedrooms;
            if (p.bathrooms) form.bathrooms.value = p.bathrooms;

            // Images
            existingImages = p.images || [];
            renderImageGrid();

            document.getElementById('loadingState').classList.add('hidden');
            document.getElementById('editFormContainer').classList.remove('hidden');
        } catch (err) {
            showError('Error loading property data: ' + err.message);
        }
    }

    function renderImageGrid() {
        const grid = document.getElementById('imageGrid');
        grid.innerHTML = '';

        // Existing Images
        existingImages.forEach((img, idx) => {
            const div = createImagePreview(img, idx, true);
            grid.appendChild(div);
        });

        // New Selected Files
        selectedFiles.forEach((file, idx) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                const div = createImagePreview(e.target.result, idx, false);
                grid.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
    }

    function createImagePreview(src, idx, isExisting) {
        const div = document.createElement('div');
        div.className = 'relative w-24 h-24 rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700';
        div.innerHTML = '<img src="' + src + '" class="w-full h-full object-cover">' +
            '<button type="button" class="absolute top-0 right-0 bg-red-500 text-white p-1 rounded-bl-lg hover:bg-red-600 transition-colors">' +
            '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg></button>';
        
        div.querySelector('button').onclick = () => {
            if (isExisting) {
                existingImages.splice(idx, 1);
            } else {
                selectedFiles.splice(idx, 1);
            }
            renderImageGrid();
        };
        return div;
    }

    function togglePropertyFields(type) {
        const pf = document.getElementById('plotFields');
        const ff = document.getElementById('farmlandFields');
        const of = document.getElementById('otherPropertyFields');
        const ai = document.getElementById('areaInput');

        pf.classList.toggle('hidden', type !== 'plot');
        ff.classList.toggle('hidden', type !== 'farmland');
        of.classList.toggle('hidden', (type === 'plot' || type === 'farmland'));
        
        if (type === 'plot' || type === 'farmland') {
            document.getElementById('areaFieldContainer').classList.add('hidden');
        } else {
            document.getElementById('areaFieldContainer').classList.remove('hidden');
        }
    }

    function setupEventListeners() {
        const form = document.getElementById('editForm');
        
        // Property Type Change
        form.querySelectorAll('input[name="property_type"]').forEach(r => {
            r.onchange = (e) => togglePropertyFields(e.target.value);
        });

        // Image Upload
        const zone = document.getElementById('dropZone');
        const input = document.getElementById('imageInput');

        zone.onclick = () => input.click();
        input.onchange = (e) => {
            const files = Array.from(e.target.files);
            if (existingImages.length + selectedFiles.length + files.length > 5) {
                showError('Maximum 5 images allowed');
                return;
            }
            selectedFiles = [...selectedFiles, ...files];
            renderImageGrid();
        };

        // Submit
        form.onsubmit = async (e) => {
            e.preventDefault();
            const token = localStorage.getItem('token');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());
            
            // Handle amenities (if you add them back)
            data.images = existingImages;

            try {
                showPageLoader('Synchronizing changes...');
                
                // Upload new images first
                if (selectedFiles.length > 0) {
                    const imgData = new FormData();
                    selectedFiles.forEach(f => imgData.append('images', f));
                    const upRes = await fetch('/api/upload/property-images', {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token },
                        body: imgData
                    });
                    if (upRes.ok) {
                        const upResData = await upRes.json();
                        data.images = [...data.images, ...(upResData.images || [])];
                    }
                }

                const res = await fetch('/api/properties/' + propertyId, {
                    method: 'PUT',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token 
                    },
                    body: JSON.stringify(data)
                });

                if (res.ok) {
                    document.getElementById('editFormContainer').classList.add('hidden');
                    document.getElementById('successMessage').classList.remove('hidden');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                } else {
                    const err = await res.json();
                    showError(err.error || 'Update failed');
                }
            } catch (err) {
                showError('Network error during update');
            } finally {
                hidePageLoader();
            }
        };
    }
</script>
` }) %>
