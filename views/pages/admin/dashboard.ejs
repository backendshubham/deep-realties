                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <a href="/admin/list-property" class="action-btn flex items-center justify-between p-5 bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm hover:border-emerald-200">
                        <div class="flex items-center gap-3">
                            <span class="text-xl">🏢</span>
                            <span class="font-bold text-gray-700 dark:text-gray-200">List New Property</span>
                        </div>
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    </a>
                    <a href="/admin/properties" class="action-btn flex items-center justify-between p-5 bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm hover:border-emerald-200">
                        <div class="flex items-center gap-3">
                            <span class="text-xl">🛠️</span>
                            <span class="font-bold text-gray-700 dark:text-gray-200">Manage All Listings</span>
