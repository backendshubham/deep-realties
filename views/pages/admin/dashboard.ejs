            <!-- Content Options -->
            <div class="glass-card p-8 rounded-[2.5rem]">
                <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Discovery Tools</h2>
                <div class="space-y-3">
                    <a href="/admin/rentals" class="flex items-center justify-between p-4 bg-gray-50/50 dark:bg-gray-800/50 rounded-xl hover:bg-emerald-50 dark:hover:bg-emerald-900/10 transition-colors">
                        <span class="text-sm font-bold text-gray-600 dark:text-gray-300">Rentals</span>
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                    <a href="/admin/projects" class="flex items-center justify-between p-4 bg-gray-50/50 dark:bg-gray-800/50 rounded-xl hover:bg-emerald-50 dark:hover:bg-emerald-900/10 transition-colors">
                        <span class="text-sm font-bold text-gray-600 dark:text-gray-300">Exclusive Projects</span>
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                    <a href="/admin/events" class="flex items-center justify-between p-4 bg-gray-50/50 dark:bg-gray-800/50 rounded-xl hover:bg-emerald-50 dark:hover:bg-emerald-900/10 transition-colors">
                        <span class="text-sm font-bold text-gray-600 dark:text-gray-300">Live Events</span>
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                    <a href="/admin/blogs" class="flex items-center justify-between p-4 bg-gray-50/50 dark:bg-gray-800/50 rounded-xl hover:bg-emerald-50 dark:hover:bg-emerald-900/10 transition-colors">
                        <span class="text-sm font-bold text-gray-600 dark:text-gray-300">Editorial Panel</span>
                        <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Call to Action Card -->
        <div class="bg-gradient-to-br from-gray-900 to-gray-800 dark:from-emerald-900/40 dark:to-teal-900/40 rounded-[2.5rem] p-10 text-white relative overflow-hidden shadow-2xl">
            <div class="relative z-10">
                <h2 class="text-3xl font-display font-bold mb-4">DeepRealties Intelligence</h2>
                <p class="text-gray-300 dark:text-emerald-100 max-w-2xl text-lg leading-relaxed mb-6">
                    Manage the future of Indore's real estate. Ensure every listing is verified and every inquiry is answered with premium precision.
                </p>
                <div class="flex flex-wrap gap-6 text-sm font-bold uppercase tracking-widest text-emerald-400">
                    <span class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>Verified Network</span>
                    <span class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>Expert Guidance</span>
                    <span class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>Market Authority</span>
                </div>
            </div>
            <div class="absolute right-0 top-0 w-1/3 h-full bg-gradient-to-l from-emerald-500/10 to-transparent pointer-events-none"></div>
        </div>
    </div>
</div>

<script>
    async function loadAdminDashboard() {
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = '/login';
            return;
        }
        
        // Verify user is admin
        try {
            const userRes = await fetch('/api/auth/me', {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (userRes.ok) {
                const userData = await userRes.json();
                if (!userData.user || userData.user.role !== 'admin') {
                    if (typeof window.showError === 'function') window.showError('Admin access required');
                    setTimeout(() => {
                        window.location.href = '/dashboard';
                    }, 2000);
                    return;
                }
            } else {
                window.location.href = '/login';
                return;
            }
        } catch (error) {
            console.error('Error verifying admin access:', error);
            window.location.href = '/login';
            return;
        }
        
        try {
            const response = await fetch('/api/admin/dashboard', {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            
            if (response.status === 403) {
                if (typeof window.showError === 'function') window.showError('Admin access required');
                setTimeout(() => {
                    window.location.href = '/dashboard';
                }, 2000);
                return;
            }
            
            const data = await response.json();
            
            if (data.stats) {
                // Simplified count update (no animation for now to ensure stability)
                document.getElementById('totalUsers').textContent = data.stats.totalUsers;
                document.getElementById('totalProperties').textContent = data.stats.totalProperties;
                document.getElementById('pendingProperties').textContent = data.stats.pendingProperties;
                document.getElementById('unreadEnquiries').textContent = data.stats.unreadEnquiries;
                document.getElementById('unreadContacts').textContent = data.stats.unreadContacts;
            }
            
            if (typeof window.hidePageLoader === 'function') {
                window.hidePageLoader();
            }
        } catch (error) {
            console.error('Error loading admin dashboard:', error);
            if (typeof window.hidePageLoader === 'function') {
                window.hidePageLoader();
            }
        }
    }
    
    document.addEventListener('DOMContentLoaded', loadAdminDashboard);
</script>
` }) %>
` }) %>

