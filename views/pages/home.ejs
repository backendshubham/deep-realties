        <!-- Abstract Shapes -->
        <div class="absolute bottom-0 right-0 w-1/3 h-1/3 bg-emerald-50 dark:bg-emerald-900/10 rounded-tl-full -z-10">
        </div>
        <div class="absolute top-0 left-0 w-1/4 h-1/4 bg-lux-gold/5 rounded-br-full -z-10"></div>
    </section>

    <script>
        // Intersection Observer for scroll animations
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, observerOptions);

        // Observe all animated elements
        document.addEventListener('DOMContentLoaded', function () {
            // Observe fade-in elements
            document.querySelectorAll('.fade-in-up, .fade-in-left, .fade-in-right, .scale-in, .service-card').forEach(el => {
                observer.observe(el);
            });

            // Number counter animation
            function animateCounter(element) {
                const target = parseInt(element.getAttribute('data-target'));
                const unit = element.getAttribute('data-unit') || '+';
                const duration = 2000; // 2 seconds
                const increment = target / (duration / 16); // 60fps
                let current = 0;

                const updateCounter = () => {
                    current += increment;
                    if (current < target) {
                        element.textContent = Math.floor(current) + unit;
                        requestAnimationFrame(updateCounter);
                    } else {
                        element.textContent = target + unit;
                    }
                };

                updateCounter();
            }

            // Observe stat items for counter animation
            const statObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const counter = entry.target.querySelector('.counter-number');
                        if (counter && !counter.classList.contains('counted')) {
                            counter.classList.add('counted');
                            animateCounter(counter);
                        }
                    }
                });
            }, { threshold: 0.5 });

            document.querySelectorAll('.stat-item').forEach(el => {
                statObserver.observe(el);
            });

            // Simple testimonials slider
            const testimonials = [
                {
                    quote: '\"Great investment advice and clear dealings. My portfolio has grown a lot with their help.\"',
                    name: 'Priya Patel',
                    role: 'Property Investor',
                    initials: 'PP',
                    tag: 'Commercial Space',
                    location: 'Indore'
                },
                {
                    quote: '\"DeepRealties made selling our family home smooth and stress-free. We got the right buyer at the right price.\"',
                    name: 'Rahul Sharma',
                    role: 'Home Seller',
                    initials: 'RS',
                    tag: 'Residential Villa',
                    location: 'Bhopal'
                },
                {
                    quote: '\"From shortlisting properties to final registration, their team guided us at every step. Highly recommended.\"',
                    name: 'Neha & Amit Verma',
                    role: 'First‑time Home Buyers',
                    initials: 'NV',
                    tag: '3BHK Apartment',
                    location: 'Indore'
                }
            ];

            const quoteEl = document.getElementById('testimonialQuote');
            const nameEl = document.getElementById('testimonialName');
            const roleEl = document.getElementById('testimonialRole');
            const initialsEl = document.getElementById('testimonialInitials');
            const tagEl = document.getElementById('testimonialTag');
            const locationEl = document.getElementById('testimonialLocation');
            const dots = document.querySelectorAll('.testimonial-dot');

            let currentTestimonial = 0;
            let testimonialTimer;

            function renderTestimonial(index) {
                const t = testimonials[index];
                if (!t) return;

                currentTestimonial = index;

                if (quoteEl) quoteEl.textContent = t.quote;
                if (nameEl) nameEl.textContent = t.name;
                if (roleEl) roleEl.textContent = t.role;
                if (initialsEl) initialsEl.textContent = t.initials;
                if (tagEl) tagEl.textContent = t.tag;
                if (locationEl) locationEl.textContent = t.location;

                if (dots && dots.length) {
                    dots.forEach((dot, i) => {
                        if (i === index) {
                            dot.classList.remove('bg-slate-300', 'dark:bg-white/20', 'bg-slate-200', 'dark:bg-white/10');
                            dot.classList.add('bg-emerald-600', 'dark:bg-emerald-400');
                            dot.style.width = '2.5rem';
                        } else {
                            dot.classList.add('bg-slate-200', 'dark:bg-white/10');
                            dot.classList.remove('bg-emerald-600', 'dark:bg-emerald-400');
                            dot.style.width = '1rem';
                        }
                    });
                }
            }

            function startTestimonialAutoPlay() {
                if (testimonialTimer) clearInterval(testimonialTimer);
                testimonialTimer = setInterval(() => {
                    const next = (currentTestimonial + 1) % testimonials.length;
                    renderTestimonial(next);
                }, 2000); // faster, feels like continuous sliding
            }

            // If testimonials API is available, load dynamically; otherwise fallback to static array.
            // If there is only ONE testimonial in DB, we blend it into the default set so the slider still cycles.
            async function initTestimonials() {
                try {
                    const res = await fetch('/api/testimonials');
                    if (res.ok) {
                        const data = await res.json();
                        if (Array.isArray(data.testimonials) && data.testimonials.length) {
                            const fromApi = data.testimonials.map(t => ({
                                quote: '\"' + (t.quote || '') + '\"',
                                name: t.name || '',
                                role: t.role || '',
                                initials: t.initials || (t.name || '').split(' ').map(p => p[0]).join('').slice(0, 2).toUpperCase(),
                                tag: t.tag || '',
                                location: t.location || ''
                            }));
                            if (fromApi.length >= 2) {
                                // Fully replace when we have 2+ real testimonials
                                testimonials.splice(0, testimonials.length, ...fromApi);
                            } else if (fromApi.length === 1) {
                                // Blend single real testimonial into first slot but keep defaults for continuous cycling
                                testimonials[0] = fromApi[0];
                            }
                        }
                    }
                } catch (e) {
                    console.warn('Unable to load testimonials from API, using defaults');
                }

                if (quoteEl && dots.length) {
                    dots.forEach(dot => {
                        dot.addEventListener('click', () => {
                            const idx = parseInt(dot.getAttribute('data-index') || '0', 10);
                            renderTestimonial(idx);
                            startTestimonialAutoPlay();
                        });
                    });

                    renderTestimonial(0);
                    startTestimonialAutoPlay();
                }
            }

            initTestimonials();

            // Load latest blog posts
            async function loadLatestBlogs() {
                const blogGrid = document.getElementById('blogGrid');
                if (!blogGrid) return;

                try {
                    const res = await fetch('/api/blogs');
                    if (!res.ok) throw new Error('Failed to fetch blogs');

                    const data = await res.json();
                    const blogs = data.blogs || [];

                    if (blogs.length === 0) {
                        blogGrid.innerHTML = \`
                        <div class="col-span-full text-center py-12">
                            <div class="w-16 h-16 bg-emerald-100 dark:bg-emerald-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
                                <svg class="w-8 h-8 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
                                </svg>
                            </div>
                            <p class="text-gray-500 dark:text-gray-400">No blog posts yet. Check back soon!</p>
                        </div>
                    \`;
                    return;
                }

                // Show only latest 4 blogs
                const latestBlogs = blogs.slice(0, 4);
                
                blogGrid.innerHTML = latestBlogs.map((blog, index) => {
                    const publishedDate = blog.published_at || blog.created_at;
                    const formattedDate = publishedDate 
                        ? new Date(publishedDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' })
                        : '';
                    
                    const excerpt = blog.excerpt || (blog.content ? blog.content.substring(0, 120) + '...' : '');
                    const imageUrl = blog.featured_image_url || 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=600&h=400&fit=crop';
                    
                    return \`
                        <a href="/blogs/\${blog.slug}" class="scale-in group bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm border border-gray-200 dark:border-gray-700 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 block" style="transition-delay: \${index * 0.1}s">
                            <div class="aspect-video overflow-hidden">
                                <img src="\${imageUrl}" alt="\${blog.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            </div>
                            <div class="p-5 sm:p-6">
                                <div class="flex items-center space-x-2 mb-3">
                                    <span class="badge-text text-xs px-2 py-1 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full">
                                        BLOG
                                    </span>
                                    \${formattedDate ? \`<span class="text-xs text-gray-500 dark:text-gray-400">\${formattedDate}</span>\` : ''}
                                </div>
                                <h3 class="card-title text-lg sm:text-xl text-gray-900 dark:text-white mb-2 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors line-clamp-2">
                                    \${blog.title}
                                </h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-3">
                                    \${excerpt}
                                </p>
                                <div class="flex items-center text-emerald-600 dark:text-emerald-400 text-sm font-medium group-hover:translate-x-2 transition-transform">
                                    <span>Read More</span>
                                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                            </div>
                        </a>
                    \`;
                }).join('');

                // Trigger animations
                setTimeout(() => {
                    blogGrid.querySelectorAll('.scale-in').forEach(el => {
                        observer.observe(el);
                    });
                }, 100);
                
            } catch (error) {
                console.error('Error loading blogs:', error);
                blogGrid.innerHTML = \`
                    <div class="col-span-full text-center py-12">
                        <div class="w-16 h-16 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <p class="text-gray-500 dark:text-gray-400">Unable to load blog posts. Please try again later.</p>
                    </div>
                \`;
            }
        }

        loadLatestBlogs();
    });
    </script>
    ` }) %>