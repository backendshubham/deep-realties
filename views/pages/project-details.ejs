<%- include('../layouts/main', { content: `
<!-- Project Hero Section -->
<section class="relative min-h-[70vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img id="projectHeroImage" src="https://images.unsplash.com/photo-1481253127861-174458393b48?auto=format&fit=crop&q=80" 
             alt="Luxury Project" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-lux-midnight via-lux-midnight/60 to-transparent dark:from-black dark:via-black/80 dark:to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="max-w-4xl">
            <span id="projectStatusBadge" class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-[0.3em] mb-8 shadow-2xl">
                LANDMARK IN PROGRESS
            </span>
            
            <h1 id="projectName" class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-white mb-8 leading-tight">
                Architecting <br/>
                <span class="text-emerald-400">The Future</span>
            </h1>
            
            <div class="flex flex-wrap items-center gap-8 text-white/70">
                <div class="flex items-center">
                    <svg class="w-6 h-6 mr-3 text-emerald-400" fill="currentColor" viewBox="0 0 20 20"><path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"></path></svg>
                    <span id="projectLocation" class="text-lg font-medium tracking-wide">Indore, MP</span>
                </div>
                <div class="h-8 w-px bg-white/20"></div>
                <div class="flex items-center">
                    <span id="projectPrice" class="text-3xl font-display font-bold text-emerald-400">₹——</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values & Scope Section -->
<section class="py-24 bg-white dark:bg-lux-midnight relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-20 items-start">
            <!-- Left: The Narrative -->
            <div>
                <h2 class="text-xs font-bold text-emerald-500 uppercase tracking-[0.4em] mb-8">Vision & Landmark</h2>
                <div id="projectDescription" class="text-2xl md:text-3xl font-display font-light text-gray-900 dark:text-white leading-relaxed mb-12">
                    Loading the architectural narrative of this landmark development...
                </div>
                
                <div id="highlightsSection" class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
                    <!-- Dynamic Highlights -->
                </div>
            </div>

            <!-- Right: Assets & Amenities -->
            <div class="space-y-12">
                <div class="glass-panel p-10 rounded-[3rem] border-gray-100 dark:border-white/10 shadow-xl">
                    <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-8">Asset Details</h3>
                    <div id="projectStats" class="grid grid-cols-2 gap-8">
                        <div>
                            <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Total Units</p>
                            <p id="totalUnits" class="text-2xl font-bold text-gray-900 dark:text-white">——</p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Availability</p>
                            <p id="availableUnits" class="text-2xl font-bold text-gray-900 dark:text-white">——</p>
                        </div>
                        <div class="col-span-2">
                            <p class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-2">Possession Timeline</p>
                            <p id="possessionDate" class="text-2xl font-bold text-gray-900 dark:text-white">——</p>
                        </div>
                    </div>
                </div>

                <div id="amenitiesCard" class="glass-panel p-10 rounded-[3rem] border-gray-100 dark:border-white/10 bg-emerald-500/5">
                    <h3 class="text-xs font-bold text-emerald-500 uppercase tracking-widest mb-8">Curated Amenities</h3>
                    <div id="amenitiesGrid" class="flex flex-wrap gap-3">
                        <!-- Dynamic -->
                    </div>
                </div>

                <div class="pt-8">
                    <a href="/contact" class="block w-full py-6 bg-emerald-600 hover:bg-emerald-500 text-white text-center font-bold text-lg rounded-[2.5rem] transition-all shadow-2xl shadow-emerald-500/20 uppercase tracking-widest">
                        Speak to Portfolio Manager
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Visionary Gallery -->
<section id="gallerySection" class="py-24 bg-gray-50 dark:bg-black/20 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-display font-bold text-gray-900 dark:text-white mb-4">Architectural Showcase</h2>
            <div class="w-20 h-1 bg-emerald-500 mx-auto"></div>
        </div>
        
        <div id="projectGallery" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Dynamic Images -->
        </div>
    </div>
</section>

<script>
    async function loadProjectDetails() {
        const pathParts = window.location.pathname.split('/');
        const projectId = pathParts[pathParts.length - 1];
        
        try {
            const response = await fetch('/api/projects/' + projectId);
            if (!response.ok) throw new Error('Project not found');
            const data = await response.json();
            const p = data.project;
            
            if (!p) throw new Error('Project not found');

            // Update Text
            document.getElementById('projectName').innerHTML = p.name.replace(' ', '<br/><span class="text-emerald-400">') + '</span>';
            document.getElementById('projectLocation').textContent = \\\`\\\${p.location}, \\\${p.city}\\\`;
            document.getElementById('projectDescription').textContent = p.description || 'A landmark development redefining luxury living and commercial excellence.';
            
            const min = p.price_range_min ? '₹' + p.price_range_min.toLocaleString() : 'Price on request';
            document.getElementById('projectPrice').textContent = p.price_range_max ? \\\`\\\${min} - ₹\\\${p.price_range_max.toLocaleString()}\\\` : min;
            
            document.getElementById('projectStatusBadge').textContent = p.status.toUpperCase();
            document.getElementById('totalUnits').textContent = p.total_units || '—';
            document.getElementById('availableUnits').textContent = p.available_units || '—';
            document.getElementById('possessionDate').textContent = p.possession_date ? new Date(p.possession_date).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : 'Coming Soon';

            if (p.images && p.images[0]) {
                document.getElementById('projectHeroImage').src = p.images[0];
            }

            // Highlights
            if (p.highlights && p.highlights.length > 0) {
                const grid = document.getElementById('highlightsSection');
                grid.innerHTML = p.highlights.map(h => \\\`
                    <div class="flex items-start">
                        <div class="w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-500 mr-4 flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <div>
                            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed font-medium">\\\${h}</p>
                        </div>
                    </div>
                \\\`).join('');
            }

            // Amenities
            if (p.amenities && p.amenities.length > 0) {
                const grid = document.getElementById('amenitiesGrid');
                grid.innerHTML = p.amenities.map(a => \\\`
                    <span class="px-5 py-2 bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-[10px] font-bold uppercase tracking-widest rounded-full">
                        \\\${a}
                    </span>
                \\\`).join('');
            } else {
                document.getElementById('amenitiesCard').classList.add('hidden');
            }

            // Gallery
            if (p.images && p.images.length > 1) {
                const grid = document.getElementById('projectGallery');
                grid.innerHTML = p.images.slice(1).map(img => \\\`
                    <div class="relative h-80 overflow-hidden rounded-[2.5rem] group">
                        <img src="\\\${img}" class="w-full h-full object-cover transform scale-110 group-hover:scale-100 transition-transform duration-1000">
                    </div>
                \\\`).join('');
            } else {
                document.getElementById('gallerySection').classList.add('hidden');
            }

        } catch (e) {
            console.error(e);
            document.body.innerHTML = \\\`
                <div class="min-h-screen flex items-center justify-center bg-lux-midnight text-white text-center p-8">
                    <div>
                        <h1 class="text-6xl font-display font-bold mb-4">404</h1>
                        <p class="text-xl text-gray-400 mb-8">This development blueprint is currently being refined.</p>
                        <a href="/projects" class="px-8 py-3 bg-emerald-600 text-white rounded-xl font-bold">Return to Projects</a>
                    </div>
                </div>
            \\\`;
        }
    }

    document.addEventListener('DOMContentLoaded', loadProjectDetails);
</script>
` }) %>
