<%- include('../layouts/main', { content: `
<!-- Asset Library Canvas -->
<div class="min-h-screen relative py-32 px-4 sm:px-6 lg:px-8 overflow-hidden bg-white dark:bg-lux-midnight transition-colors">
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/5 blur-[120px] pointer-events-none"></div>
        <div class="absolute top-1/4 left-0 w-1/4 h-1/2 bg-emerald-900/5 blur-[150px] pointer-events-none"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
        <!-- Header -->
        <header class="mb-16 animate-[fadeInUp_0.6s_ease]">
            <nav class="flex mb-8 text-[10px] font-bold uppercase tracking-widest text-gray-400">
                <a href="/dashboard" class="hover:text-emerald-500 transition-colors">Portfolio</a>
                <span class="mx-2">/</span>
                <span class="text-emerald-500 italic">Asset Library</span>
            </nav>

            <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-10">
                <div>
                    <h1 class="text-4xl md:text-6xl font-display font-bold text-gray-900 dark:text-white tracking-tight mb-4">
                        Your <span class="text-emerald-500">Holdings</span>
                    </h1>
                    <p class="text-gray-500 dark:text-gray-400 text-sm font-medium max-w-xl">
                        A curated repository of your real estate investments and verified listings on the DeepRealties platform.
                    </p>
                </div>
                <a href="/sell" class="px-10 py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs uppercase tracking-[0.2em] rounded-2xl shadow-2xl shadow-emerald-500/20 transition-all active:scale-[0.98]">
                    List New Asset
                </a>
            </div>
        </header>

        <!-- Search & Filter Bar -->
        <div class="glass-panel p-8 rounded-[3rem] border-gray-100 dark:border-white/10 shadow-xl mb-16 flex flex-col md:flex-row items-center gap-6">
            <div class="flex-1 relative w-full">
                <input type="text" id="searchInput" placeholder="Search by asset title, location or reference ID..." 
                       class="w-full pl-14 pr-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 text-gray-900 dark:text-white outline-none focus:border-emerald-500/50 transition-all font-medium">
                <svg class="absolute left-6 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            
            <div class="flex items-center gap-4 w-full md:w-auto">
                <select id="statusFilter" class="flex-1 md:flex-none px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 text-sm font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest outline-none focus:border-emerald-500/50 appearance-none">
                    <option value="">Status: All</option>
                    <option value="approved">Approved</option>
                    <option value="pending">Pending</option>
                    <option value="rejected">Rejected</option>
                </select>
            </div>
        </div>

        <!-- Asset Grid -->
        <div id="loadingState" class="text-center py-40">
            <div class="inline-loader-spinner mx-auto mb-4 border-t-emerald-500"></div>
            <p class="text-gray-400 font-medium font-display uppercase tracking-widest text-[10px]">Accessing Vault...</p>
        </div>

        <div id="emptyState" class="hidden text-center py-40 glass-panel rounded-[4rem] border-dashed border-gray-200 dark:border-white/10">
            <p class="text-gray-500 dark:text-gray-400 text-lg mb-8 italic">Your asset vault is currently empty.</p>
            <a href="/sell" class="px-8 py-4 bg-emerald-500/10 border border-emerald-500/30 text-emerald-500 font-bold rounded-2xl text-[10px] uppercase tracking-widest hover:bg-emerald-500 hover:text-white transition-all">Begin Your Legacy</a>
        </div>

        <div id="propertiesList" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <!-- Dynamic Assets -->
        </div>

        <!-- Pagination -->
        <div id="paginationContainer" class="hidden mt-20 pt-12 border-t border-gray-100 dark:border-white/5 flex flex-col md:flex-row items-center justify-between gap-8">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">
                Showing Area <span id="paginationInfo" class="text-emerald-500 italic">0-0</span> of <span id="paginationTotal" class="text-gray-900 dark:text-white">0</span> Assets
            </p>
            <div id="pageNumbers" class="flex items-center gap-3">
                <!-- Dynamic -->
            </div>
        </div>
    </div>
</div>

<script>
    let filterDebounce;
    let currentPage = 1;
    let limit = 9;

    async function loadMyProperties(page = 1) {
        currentPage = page;
        const token = localStorage.getItem('token');
        if (!token) return window.location.href = '/login';

        const loading = document.getElementById('loadingState');
        const empty = document.getElementById('emptyState');
        const list = document.getElementById('propertiesList');
        const pag = document.getElementById('paginationContainer');

        list.classList.add('hidden');
        loading.classList.remove('hidden');
        empty.classList.add('hidden');
        pag.classList.add('hidden');

        try {
            const search = document.getElementById('searchInput').value;
            const status = document.getElementById('statusFilter').value;
            
            const params = new URLSearchParams({ page, limit, search, status });
            const res = await fetch('/api/properties/my-properties/list?' + params.toString(), {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            const data = await res.json();
            const props = data.properties || [];
            const meta = data.pagination || { total: 0, pages: 1 };

            loading.classList.add('hidden');

            if (props.length === 0) {
                empty.classList.remove('hidden');
                return;
            }

            list.classList.remove('hidden');
            pag.classList.remove('hidden');
            
            // Render Assets
            list.innerHTML = props.map((p, index) => {
                const statusClass = p.status === 'approved' ? 'bg-emerald-500' : p.status === 'pending' ? 'bg-amber-500' : 'bg-red-500';
                
                return \\\`
                    <div class="group glass-panel rounded-[3rem] overflow-hidden bg-white dark:bg-lux-midnight border-gray-100 dark:border-white/10 hover:border-emerald-500/30 transition-all duration-700 shadow-xl animate-[fadeInUp_\\\${0.4 + (index*0.1)}s_ease-out]">
                        <div onclick="window.location.href='/properties/\\\${p.id}'" class="relative h-64 overflow-hidden cursor-pointer">
                            <img src="\\\${p.images && p.images[0] || 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&q=80'}" 
                                 class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-1000">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                            <div class="absolute top-6 left-6">
                                <span class="\\\${statusClass} text-white text-[9px] font-bold uppercase tracking-[0.2em] px-4 py-2 rounded-full shadow-lg">
                                    \\\${p.status}
                                </span>
                            </div>
                            <div class="absolute bottom-6 left-6">
                                <p class="text-white font-bold text-lg">₹\\\${p.price.toLocaleString()}</p>
                                <p class="text-white/60 text-[10px] font-bold uppercase tracking-widest mt-1">\\\${p.locality || 'Verified Area'}</p>
                            </div>
                        </div>
                        
                        <div class="p-8">
                            <h3 class="text-xl font-display font-bold text-gray-900 dark:text-white mb-6 line-clamp-1 group-hover:text-emerald-500 transition-colors">\\\${p.title}</h3>
                            
                            <div class="grid grid-cols-2 gap-4 mb-8">
                                <div class="p-4 bg-gray-50 dark:bg-white/5 rounded-2xl border border-gray-100 dark:border-white/5">
                                    <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-1">Type</p>
                                    <p class="text-[11px] font-bold text-gray-900 dark:text-white capitalize">\\\${p.property_type}</p>
                                </div>
                                <div class="p-4 bg-gray-50 dark:bg-white/5 rounded-2xl border border-gray-100 dark:border-white/5">
                                    <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-1">Area</p>
                                    <p class="text-[11px] font-bold text-gray-900 dark:text-white">\\\${p.area_sqft} SqFt</p>
                                </div>
                            </div>

                            <div class="flex gap-4">
                                <button onclick="window.location.href='/properties/\\\${p.id}'" class="flex-1 py-4 bg-emerald-600 hover:bg-emerald-500 text-white text-[9px] font-bold uppercase tracking-[0.2em] rounded-2xl transition-all shadow-lg shadow-emerald-500/10">Manage</button>
                                <button class="px-5 py-4 bg-gray-100 dark:bg-white/5 text-gray-400 rounded-2xl hover:text-emerald-500 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                \\\`;
            }).join('');

            // Pagination
            document.getElementById('paginationTotal').textContent = meta.total;
            const start = meta.total === 0 ? 0 : (meta.page - 1) * limit + 1;
            const end = Math.min(meta.page * limit, meta.total);
            document.getElementById('paginationInfo').textContent = \\\`\\\${start}-\\\${end}\\\`;

            const pages = document.getElementById('pageNumbers');
            pages.innerHTML = '';
            for(let i=1; i <= meta.pages; i++) {
                pages.innerHTML += \\\`
                    <button onclick="loadMyProperties(\\\${i})" class="w-10 h-10 rounded-xl flex items-center justify-center text-xs font-bold transition-all \\\${i === page ? 'bg-emerald-600 text-white shadow-xl shadow-emerald-500/20' : 'bg-gray-100 dark:bg-white/5 text-gray-400 hover:text-emerald-500' }">
                        \\\${i}
                    </button>
                \\\`;
            }

        } catch (e) {
            console.error(e);
        }
    }

    document.getElementById('searchInput').addEventListener('input', () => {
        clearTimeout(filterDebounce);
        filterDebounce = setTimeout(() => loadMyProperties(1), 500);
    });

    document.getElementById('statusFilter').addEventListener('change', () => loadMyProperties(1));

    document.addEventListener('DOMContentLoaded', () => loadMyProperties(1));
</script>
` }) %>
