<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[50vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1540575861501-7cf05a4b125a?auto=format&fit=crop&q=80" 
             alt="Luxury Events" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-r from-lux-midnight via-lux-midnight/80 to-transparent dark:from-black dark:via-black/90 dark:to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="max-w-3xl">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
                EXCLUSIVE GATHERINGS
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
                Connect at the <br/>
                <span class="text-emerald-400">Pinnacle</span>
            </h1>
            
            <p class="text-lg md:text-xl text-white/70 max-w-2xl leading-relaxed">
                Join our elite circle of builders, investors, and connoisseurs at exclusive inaugurations and industry-shaping meetups.
            </p>
        </div>
    </div>
</section>

<!-- Event Filtering & Tabs -->
<section class="py-12 bg-white dark:bg-lux-midnight border-b border-gray-100 dark:border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-8">
            <div class="flex p-1 bg-gray-100 dark:bg-white/5 rounded-2xl w-fit">
                <button onclick="switchTab('upcoming')" id="upcomingTab" 
                        class="px-8 py-3 rounded-xl font-bold text-sm transition-all bg-emerald-600 text-white shadow-lg">
                    Upcoming Galas
                </button>
                <button onclick="switchTab('past')" id="pastTab" 
                        class="px-8 py-3 rounded-xl font-bold text-sm transition-all text-gray-500 hover:text-gray-900 dark:hover:text-white">
                    Past Highlights
                </button>
            </div>
            
            <div class="flex items-center space-x-4">
                <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Filter by category:</span>
                <div class="flex space-x-2">
                    <button class="px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-[10px] font-bold uppercase tracking-widest">All</button>
                    <button class="px-4 py-2 rounded-full border border-gray-100 dark:border-white/10 text-gray-400 text-[10px] font-bold uppercase tracking-widest hover:border-emerald-500 transition-colors">Inaugurations</button>
                    <button class="px-4 py-2 rounded-full border border-gray-100 dark:border-white/10 text-gray-400 text-[10px] font-bold uppercase tracking-widest hover:border-emerald-500 transition-colors">Meetups</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Event Grid -->
<section class="py-24 bg-gray-50 dark:bg-black/20 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="loadingState" class="text-center py-40">
            <div class="inline-loader-spinner mx-auto mb-4 border-t-emerald-500"></div>
            <p class="text-gray-400 font-medium font-display uppercase tracking-widest text-[10px]">Preparing guest list...</p>
        </div>

        <div id="emptyState" class="hidden text-center py-40 glass-panel rounded-[2rem]">
            <p class="text-gray-500 dark:text-gray-400">No events currently scheduled. Please check back for exclusive invitations.</p>
        </div>

        <div id="eventsList" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <!-- Dynamically Loaded -->
        </div>
    </div>
</section>

<script>
    let currentTab = 'upcoming';

    document.addEventListener('DOMContentLoaded', () => loadEvents('upcoming'));

    function switchTab(tab) {
        currentTab = tab;
        const upcoming = document.getElementById('upcomingTab');
        const past = document.getElementById('pastTab');
        
        if (tab === 'upcoming') {
            upcoming.className = 'px-8 py-3 rounded-xl font-bold text-sm transition-all bg-emerald-600 text-white shadow-lg';
            past.className = 'px-8 py-3 rounded-xl font-bold text-sm transition-all text-gray-500 hover:text-gray-900 dark:hover:text-white';
        } else {
            past.className = 'px-8 py-3 rounded-xl font-bold text-sm transition-all bg-emerald-600 text-white shadow-lg';
            upcoming.className = 'px-8 py-3 rounded-xl font-bold text-sm transition-all text-gray-500 hover:text-gray-900 dark:hover:text-white';
        }
        loadEvents(tab);
    }

    async function loadEvents(type) {
        const loading = document.getElementById('loadingState');
        const empty = document.getElementById('emptyState');
        const list = document.getElementById('eventsList');

        list.innerHTML = '';
        loading.classList.remove('hidden');
        empty.classList.add('hidden');
        list.classList.add('hidden');

        try {
            const response = await fetch('/api/events?is_past=' + (type === 'past'));
            const data = await response.json();
            const events = data.events || [];

            loading.classList.add('hidden');

            if (events.length === 0) {
                empty.classList.remove('hidden');
                return;
            }

            list.classList.remove('hidden');
            list.innerHTML = events.map(event => {
                const date = new Date(event.event_date);
                const day = date.getDate();
                const month = date.toLocaleString('default', { month: 'short' }).toUpperCase();
                
                return \`
                    <div class="glass-panel group rounded-[3rem] overflow-hidden bg-white dark:bg-lux-midnight shadow-xl hover:border-emerald-500/30 transition-all duration-700">
                        <div class="relative h-72 overflow-hidden">
                            <img src="\${event.banner_image || event.images && event.images[0] || 'https://images.unsplash.com/photo-1511578314322-379afb476865?auto=format&fit=crop&q=80'}" 
                                 class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-1000">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                            
                            <!-- Date Badge -->
                            <div class="absolute top-6 left-6 w-16 h-20 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl flex flex-col items-center justify-center text-white">
                                <span class="text-2xl font-display font-bold leading-none">\${day}</span>
                                <span class="text-[10px] font-bold tracking-widest mt-1 opacity-80">\${month}</span>
                            </div>

                            <div class="absolute bottom-6 left-6">
                                <span class="inline-block px-3 py-1 bg-emerald-500 text-white text-[9px] font-bold uppercase tracking-widest rounded-full mb-2">
                                    \${event.event_type.replace('_', ' ').toUpperCase()}
                                </span>
                                <div class="text-white font-bold text-sm flex items-center">
                                    <svg class="w-4 h-4 mr-2 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                                    \${event.city}
                                </div>
                            </div>
                        </div>
                        
                        <div class="p-8">
                            <h3 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-4 line-clamp-1 group-hover:text-emerald-500 transition-colors">
                                \${event.title}
                            </h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400 mb-8 line-clamp-2 leading-relaxed">
                                \${event.description || 'Exclusive networking session focusing on the future of luxury real estate and community building.'}
                            </p>
                            
                            <div class="flex gap-4">
                                <button onclick="registerForEvent('\${event.id}')" 
                                        class="flex-1 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs uppercase tracking-widest rounded-2xl transition-all shadow-lg shadow-emerald-500/20">
                                    RSVP NOW
                                </button>
                                <button onclick="viewEventDetails('\${event.id}')" 
                                        class="px-6 py-4 bg-gray-100 dark:bg-white/5 text-gray-500 dark:text-gray-400 rounded-2xl hover:bg-emerald-500/10 hover:text-emerald-500 transition-all">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                \`;
            }).join('');
        } catch (e) {
            console.error(e);
            loading.classList.add('hidden');
            empty.classList.remove('hidden');
        }
    }

    // Modal Handling (Integrated with main.ejs functions)
    window.registerForEvent = function(id) {
        const formHTML = \`
            <div class="p-4">
                <form id="rsvpForm" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2">Full Name</label>
                            <input type="text" id="regName" required class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-white focus:border-emerald-500">
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2">Phone</label>
                            <input type="tel" id="regPhone" required class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-white focus:border-emerald-500">
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2">Email</label>
                        <input type="email" id="regEmail" required class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-white focus:border-emerald-500">
                    </div>
                    <button type="submit" class="w-full py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-2xl shadow-xl">Confirm Invitation</button>
                </form>
            </div>
        \`;
        if (window.showModal) {
            window.showModal('Exclusive Invitation Request', formHTML);
            document.getElementById('rsvpForm').addEventListener('submit', (e) => {
                e.preventDefault();
                submitRSVP(id);
            });
        }
    };

    async function submitRSVP(id) {
        const body = {
            full_name: document.getElementById('regName').value,
            email: document.getElementById('regEmail').value,
            phone: document.getElementById('regPhone').value
        };
        
        try {
            const res = await fetch(\`/api/events/\${id}/register\`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (res.ok) {
                window.showSuccess && window.showSuccess('Invitation confirmed! Looking forward to seeing you.');
                window.closeModal && window.closeModal();
            } else {
                throw new Error(data.error);
            }
        } catch (e) {
            window.showError && window.showError(e.message || 'Request failed');
        }
    }

    window.viewEventDetails = async function(id) {
        try {
            const res = await fetch('/api/events/' + id);
            const data = await res.json();
            const event = data.event;
            
            const content = \`
                <div class="space-y-6 text-gray-400">
                    <p class="leading-relaxed">\${event.description || 'No detailed description available.'}</p>
                    <div class="grid grid-cols-2 gap-6 pt-6 border-t border-white/5">
                        <div>
                            <h4 class="text-[10px] font-bold uppercase tracking-widest text-emerald-500 mb-2">When</h4>
                            <p class="text-white text-sm">\${new Date(event.event_date).toDateString()} @ \${event.event_time || 'TBA'}</p>
                        </div>
                        <div>
                            <h4 class="text-[10px] font-bold uppercase tracking-widest text-emerald-500 mb-2">Where</h4>
                            <p class="text-white text-sm">\${event.location}, \${event.city}</p>
                        </div>
                    </div>
                    \${event.agenda ? \`
                        <div>
                            <h4 class="text-[10px] font-bold uppercase tracking-widest text-emerald-500 mb-2">Agenda</h4>
                            <div class="text-sm whitespace-pre-line">\${event.agenda}</div>
                        </div>
                    \` : ''}
                </div>
            \`;
            window.showModal && window.showModal(event.title, content);
        } catch (e) {
            console.error(e);
        }
    };
</script>
` }) %>
