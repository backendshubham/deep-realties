<%
  const hasDates = blog && (blog.published_at || blog.created_at);
  const publishedDate = hasDates
    ? new Date(blog.published_at || blog.created_at).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      })
    : 'Recently Published';
%>
<%- include('../layouts/main', { content: `
<!-- Editorial Hero -->
<section class="relative min-h-[50vh] flex items-center pt-32 pb-20 overflow-hidden bg-lux-midnight dark:bg-black">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="${blog && blog.featured_image_url ? blog.featured_image_url : 'https://images.unsplash.com/photo-1434626881859-194d67b2b86f?auto=format&fit=crop&q=80'}" 
             alt="${blog && blog.title ? blog.title : 'Editorial'}" 
             class="w-full h-full object-cover blur-[2px] opacity-40">
        <div class="absolute inset-0 bg-gradient-to-t from-lux-midnight via-lux-midnight/80 to-transparent dark:from-black dark:via-black/90 dark:to-transparent"></div>
    </div>

    <!-- Decorative Glows -->
    <div class="absolute bottom-0 left-1/4 w-1/2 h-full bg-emerald-500/5 blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full text-center">
        <!-- Category & Meta -->
        <div class="flex flex-col items-center mb-8">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-[0.3em] mb-6 backdrop-blur-md">
                Insight & Perspective
            </span>
            <div class="flex items-center space-x-6 text-xs font-bold text-white/40 uppercase tracking-widest">
                <span>${publishedDate}</span>
                <span class="w-1 h-1 bg-emerald-500 rounded-full"></span>
                <span>5 Min Read</span>
            </div>
        </div>
        
        <h1 class="text-4xl md:text-6xl font-display font-bold text-white mb-8 leading-tight italic">
            ${blog && blog.title ? blog.title : 'Deep Journal Entry'}
        </h1>
        
        <div class="flex items-center justify-center space-x-4">
            <div class="w-12 h-px bg-white/20"></div>
            <div class="w-12 h-12 rounded-full border border-emerald-500/30 flex items-center justify-center text-emerald-500">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path></svg>
            </div>
            <div class="w-12 h-px bg-white/20"></div>
        </div>
    </div>
</section>

<!-- Reading Section -->
<section class="py-24 bg-white dark:bg-lux-midnight relative">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Glassmorphic Meta Sidebar (Desktop Only) -->
        <div class="hidden xl:block absolute left-[-200px] top-24 w-40 space-y-8">
            <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Curated by</p>
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-full bg-emerald-500 flex items-center justify-center text-white font-bold">D</div>
                    <span class="text-sm font-bold text-gray-900 dark:text-white">Deepak R.</span>
                </div>
            </div>
            <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Share</p>
                <div class="flex flex-col space-y-4">
                    <button class="w-10 h-10 rounded-full border border-gray-100 dark:border-white/10 flex items-center justify-center text-gray-400 hover:text-emerald-500 hover:border-emerald-500 transition-all">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557a9.83 9.83 0 01-2.828.775 4.932 4.932 0 002.165-2.724 9.864 9.864 0 01-3.127 1.195 4.916 4.916 0 00-3.593-1.554c-3.179 0-5.515 2.966-4.797 6.045A13.978 13.978 0 011.671 3.149a4.93 4.93 0 001.523 6.574 4.903 4.903 0 01-2.229-.616c-.054 2.281 1.581 4.415 3.949 4.89a4.935 4.935 0 01-2.224.084 4.928 4.928 0 004.6 3.419A9.9 9.9 0 010 19.54a13.94 13.94 0 007.548 2.212c9.142 0 14.307-7.721 13.995-14.646A10.025 10.025 0 0024 4.557z"></path></svg>
                    </button>
                    <button class="w-10 h-10 rounded-full border border-gray-100 dark:border-white/10 flex items-center justify-center text-gray-400 hover:text-emerald-500 hover:border-emerald-500 transition-all">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Main Narrative Article -->
        <article class="prose prose-xl dark:prose-invert max-w-none prose-emerald">
            <div id="blogContent" class="text-gray-900 dark:text-gray-300 leading-relaxed font-serif">
                ${blogHtml && blogHtml.length ? blogHtml : '<p class="text-gray-500 text-center italic py-20">The editorial content is being finalized by our curators.</p>'}
            </div>
        </article>

        <!-- Signature / Footer -->
        <div class="mt-24 pt-12 border-t border-gray-100 dark:border-white/5 text-center">
            <h3 class="text-3xl font-display font-bold text-gray-900 dark:text-white mb-8">Reflect & Connect</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-12 max-w-md mx-auto">
                Explore the latest insights in luxury real estate and investment through our curated Deep Journal.
            </p>
            <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
                <a href="/blogs" class="px-10 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-2xl shadow-xl shadow-emerald-500/20 transition-all uppercase tracking-widest text-xs">
                    Return to Journal
                </a>
                <a href="/contact" class="px-10 py-4 bg-white/5 border border-emerald-500/30 text-emerald-500 font-bold rounded-2xl hover:bg-emerald-500 hover:text-white transition-all uppercase tracking-widest text-xs">
                    Contact Concierge
                </a>
            </div>
        </div>
    </div>
</section>
` }) %>
