<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[40vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="/images/projects-hero.png" 
             alt="Luxury Projects" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-r from-lux-midnight/90 via-lux-midnight/60 to-transparent dark:from-black dark:via-black/95 dark:to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="max-w-3xl">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
                LANDMARK DEVELOPMENTS
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
                Our Signature <br/>
                <span class="text-emerald-400">Projects</span>
            </h1>
            
            <p class="text-lg md:text-xl text-white/70 max-w-2xl leading-relaxed">
                Explore our portfolio of high-end residential colonies, commercial landmarks, and visionary township developments.
            </p>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="py-20 bg-white dark:bg-lux-midnight relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="glass-panel p-8 rounded-3xl border-gray-100 dark:border-white/10 hover:border-emerald-500/50 transition-all group">
                <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Ongoing Ventures</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Experience progress in real-time with our current developments featuring customizable living options.</p>
            </div>
            
            <div class="glass-panel p-8 rounded-3xl border-gray-100 dark:border-white/10 hover:border-emerald-500/50 transition-all group">
                <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Upcoming Blueprints</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Get exclusive pre-launch access to our next generation of luxury properties and townships.</p>
            </div>

            <div class="glass-panel p-8 rounded-3xl border-gray-100 dark:border-white/10 hover:border-emerald-500/50 transition-all group">
                <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-6 group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Proven Legacy</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Explore our portfolio of successfully delivered projects, now home to hundreds of satisfied families.</p>
            </div>
        </div>
    </div>
</section>

<!-- Mobile Filter Toggle Button -->
<button onclick="toggleMobileFilters()" class="lg:hidden fixed bottom-6 right-6 z-[95] bg-emerald-600 text-white p-4 rounded-full shadow-[0_8px_30px_rgb(16,185,129,0.4)] hover:shadow-[0_8px_30px_rgb(16,185,129,0.6)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center group" title="Filters">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
</button>

<!-- Mobile Filter Overlay -->
<div id="filterOverlay" class="fixed inset-0 bg-lux-midnight/40 backdrop-blur-md z-[100] hidden transition-opacity duration-500" onclick="toggleMobileFilters()"></div>

<!-- Filter & Search Section -->
<section id="filterSection" class="fixed inset-y-0 right-0 z-[110] w-full max-w-sm bg-white dark:bg-lux-midnight shadow-2xl transform translate-x-full transition-transform duration-500 ease-in-out lg:static lg:w-auto lg:max-w-none lg:bg-transparent lg:shadow-none lg:transform-none lg:z-30 py-6 lg:py-12 border-l lg:border-l-0 lg:border-b border-gray-100 dark:border-white/5 lg:sticky lg:top-20 lg:backdrop-blur-xl lg:bg-white/80 dark:lg:bg-lux-midnight/80 h-full lg:h-auto overflow-y-auto lg:overflow-visible">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 h-full flex flex-col lg:block">
        
        <!-- Mobile Header inside Drawer -->
        <div class="flex items-center justify-between lg:hidden mb-8 pb-4 border-b border-gray-100 dark:border-white/5 sticky top-0 bg-white dark:bg-lux-midnight z-10 pt-2">
            <h3 class="text-xl font-display font-bold text-gray-900 dark:text-white">Refine Search</h3>
            <button onclick="toggleMobileFilters()" class="p-2 border border-gray-100 dark:border-white/10 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-white transition-colors bg-gray-50 dark:bg-white/5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div class="flex flex-col lg:flex-row lg:items-center justify-center gap-6 flex-1 lg:flex-none">
            <!-- Search Bar Search -->
            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 lg:flex lg:justify-center gap-4 max-w-2xl mx-auto w-full">
                <div class="w-full">
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">City</label>
                    <input type="text" id="searchCity" placeholder="Any City" 
                           class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                </div>
                <div class="w-full">
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Status</label>
                    <select id="searchStatus" class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all appearance-none">
                        <option value="">All Statuses</option>
                        <option value="upcoming">Upcoming</option>
                        <option value="ongoing">Ongoing</option>
                        <option value="completed">Completed</option>
                    </select>
                </div>
            </div>
            
            <div class="flex flex-col lg:flex-row gap-4 mt-8 lg:mt-0 pt-6 lg:pt-0 border-t border-gray-100 dark:border-white/5 lg:border-none pb-6 lg:pb-0">
                <button onclick="applyFiltersAndClose()" class="w-full lg:w-auto px-8 py-4 lg:py-3 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-bold transition-all shadow-lg shadow-emerald-500/20 flex items-center justify-center lg:mt-6">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    Apply Filters
                </button>
                <button onclick="clearFilters()" class="w-full lg:w-auto px-5 py-4 lg:py-3 bg-gray-50 lg:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 rounded-xl hover:bg-gray-100 dark:hover:bg-white/10 transition-all font-semibold lg:mt-6">
                    Reset
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Projects Display Section -->
<section class="py-24 bg-gray-50 dark:bg-black/20 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-display font-bold text-gray-900 dark:text-white mb-4">Portfolio Showcase</h2>
            <div class="w-20 h-1 bg-emerald-500 mx-auto"></div>
        </div>

        <div id="projectsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <!-- Dynamically Loaded -->
        </div>

        <div id="loadingState" class="hidden text-center py-40">
            <div class="inline-loader-spinner mx-auto mb-4 border-t-emerald-500"></div>
            <p class="text-gray-500 dark:text-gray-400 font-medium font-display uppercase tracking-widest text-xs">Curating architectural masterpieces...</p>
        </div>
    </div>
</section>

<script>
    function toggleMobileFilters() {
        const filterSection = document.getElementById('filterSection');
        const filterOverlay = document.getElementById('filterOverlay');
        const isHidden = filterSection.classList.contains('translate-x-full');
        
        if (isHidden) {
            filterSection.classList.remove('translate-x-full');
            filterOverlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        } else {
            filterSection.classList.add('translate-x-full');
            filterOverlay.classList.add('hidden');
            document.body.style.overflow = '';
        }
    }
    
    function clearFilters() {
        if(document.getElementById('searchCity')) document.getElementById('searchCity').value = '';
        if(document.getElementById('searchStatus')) document.getElementById('searchStatus').value = '';
        loadProjects();
    }
    
    function applyFiltersAndClose() {
        loadProjects();
        toggleMobileFilters();
    }

    async function loadProjects() {
        const grid = document.getElementById('projectsGrid');
        const loading = document.getElementById('loadingState');
        
        grid.innerHTML = '';
        loading.classList.remove('hidden');
        
        try {
            const city = document.getElementById('searchCity')?.value || '';
            const status = document.getElementById('searchStatus')?.value || '';
            const params = new URLSearchParams();
            if (city) params.append('city', city);
            if (status) params.append('status', status);

            const response = await fetch('/api/projects?' + params.toString());
            const data = await response.json();
            
            loading.classList.add('hidden');
            
            if (data.projects && data.projects.length > 0) {
                grid.innerHTML = data.projects.map(project => {
                    const statusConfig = {
                        'completed': { color: 'bg-emerald-500', text: 'Delivered' },
                        'ongoing': { color: 'bg-blue-500', text: 'In Development' },
                        'upcoming': { color: 'bg-lux-gold', text: 'Coming Soon' }
                    };
                    const status = statusConfig[project.status.toLowerCase()] || { color: 'bg-gray-500', text: project.status };
                    
                    return \`
                        <div class="glass-panel group rounded-[2.5rem] overflow-hidden hover:border-emerald-500/30 transition-all duration-700 bg-white dark:bg-lux-midnight shadow-xl">
                            <div class="relative h-80 overflow-hidden">
                                <img src="\${project.images && project.images[0] || 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&q=80'}" 
                                     class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-1000">
                                <div class="absolute inset-0 bg-gradient-to-t from-lux-midnight/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                                <div class="absolute top-6 left-6 flex space-x-2">
                                    <span class="\${status.color} text-white font-bold text-[10px] uppercase tracking-widest px-4 py-2 rounded-full shadow-lg">
                                        \${status.text}
                                    </span>
                                </div>
                            </div>
                            <div class="p-8">
                                <div class="flex items-center text-emerald-500 text-[10px] font-bold mb-3 uppercase tracking-[0.2em]">
                                    <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"></path></svg>
                                    \${project.location}, \${project.city}
                                </div>
                                <h3 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-6 group-hover:text-emerald-500 transition-colors">
                                    \${project.name}
                                </h3>
                                <div class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-white/10">
                                    <span class="text-xs text-gray-500 dark:text-gray-400 font-medium">Verified Development</span>
                                    <a href="/projects/\${project.id}" class="inline-flex items-center text-emerald-500 font-bold text-sm group/btn hover:text-emerald-400 transition-colors">
                                        Explore Scope
                                        <svg class="w-5 h-5 ml-2 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                    \`;
                }).join('');
            } else {
                grid.innerHTML = '<div class="col-span-full py-20 text-center"><p class="text-gray-500">No active projects matching your request.</p></div>';
            }
        } catch (e) {
            console.error(e);
            grid.innerHTML = '<div class="col-span-full py-20 text-center"><p class="text-red-500">Error connecting to architectural library.</p></div>';
        }
    }

    document.addEventListener('DOMContentLoaded', loadProjects);
    window.addEventListener('pageshow', (e) => e.persisted && loadProjects());
</script>
` }) %>
