<%- include('../layouts/main', { content: `
<!-- Authentication Canvas -->
<div class="min-h-screen relative flex items-center justify-center py-20 px-4 sm:px-6 lg:px-8 overflow-hidden bg-[#F8FAFC] dark:bg-lux-midnight transition-colors">
    <!-- Animated Cinematic Background -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-emerald-500/10 dark:bg-emerald-500/10 blur-[150px] animate-pulse"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-emerald-500/10 dark:bg-emerald-900/10 blur-[150px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="max-w-md w-full relative z-10">
        <!-- Brand Header -->
        <div class="text-center mb-12">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-[10px] font-bold uppercase tracking-[0.4em] mb-8 backdrop-blur-md">
                VAULT SECURITY
            </span>
            <h1 class="text-4xl md:text-5xl font-display font-bold text-lux-midnight dark:text-white mb-4 tracking-tight">
                New <span class="text-emerald-600 dark:text-emerald-400 italic font-serif">Credentials</span>
            </h1>
            <p class="text-gray-500 dark:text-white/40 text-sm font-medium tracking-wide">
                Define your new unique access key to re-enter the portfolio.
            </p>
        </div>

        <!-- Glassmorphic Card -->
        <div class="glass-panel p-10 sm:p-12 rounded-[3.5rem] border-gray-200 dark:border-white/10 shadow-2xl relative overflow-hidden backdrop-blur-2xl bg-white/80 dark:bg-white/5">
            <div id="errorMessage" class="hidden mb-8 p-5 bg-red-500/10 border border-red-500/20 text-red-500 dark:text-red-400 rounded-2xl text-xs font-bold animate-pulse flex items-center gap-3">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                <span id="errorText"></span>
            </div>
            
            <div id="successMessage" class="hidden mb-8 p-5 bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400 rounded-2xl text-xs font-bold flex items-center gap-3">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span id="successText"></span>
            </div>

            <form id="resetPasswordForm" class="space-y-8">
                <input type="hidden" id="email" name="email">
                
                <div class="group">
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Recovery Code</label>
                    <input type="text" id="otp" name="otp" required maxlength="6" 
                           class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-emerald-600 dark:text-emerald-400 text-2xl tracking-[0.5em] font-mono placeholder-gray-400 dark:placeholder-white/10 focus:border-emerald-500/50 outline-none transition-all text-center"
                           placeholder="••••••">
                </div>

                <div class="group relative">
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">New Secret Key</label>
                    <input type="password" id="new_password" name="new_password" required 
                           class="w-full px-6 py-4 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-lux-midnight dark:text-white placeholder-gray-400 dark:placeholder-white/20 focus:border-emerald-500/50 outline-none transition-all"
                           placeholder="••••••••">
                    <button type="button" onclick="togglePass()" class="absolute right-6 top-[3.25rem] text-gray-400 dark:text-white/30 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">
                        <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                    </button>
                </div>

                <button type="submit" id="submitBtn" class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-sm uppercase tracking-[0.2em] rounded-2xl shadow-2xl shadow-emerald-500/20 transition-all active:scale-[0.98] flex items-center justify-center gap-3">
                    <span id="submitText">Finalize Recovery</span>
                    <span id="submitSpinner" class="hidden spinner border-t-white !w-4 !h-4"></span>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const email = urlParams.get('email');
        const otp = urlParams.get('otp');
        if (email) document.getElementById('email').value = email;
        if (otp) document.getElementById('otp').value = otp;
    });

    function togglePass() {
        const p = document.getElementById('new_password');
        const eye = document.getElementById('eyeIcon');
        if (p.type === 'password') {
            p.type = 'text';
            eye.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943-9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>';
        } else {
            p.type = 'password';
            eye.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>';
        }
    }

    document.getElementById('resetPasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const text = document.getElementById('submitText');
        const spin = document.getElementById('submitSpinner');
        const err = document.getElementById('errorMessage');
        const ok = document.getElementById('successMessage');

        err.classList.add('hidden');
        btn.disabled = true;
        text.textContent = 'Updating Vault...';
        spin.classList.remove('hidden');

        try {
            const data = Object.fromEntries(new FormData(e.target));
            const res = await fetch('/api/auth/reset-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();

            if (res.ok) {
                ok.classList.remove('hidden');
                document.getElementById('successText').textContent = 'Security key updated. Re-routing...';
                setTimeout(() => {
                    window.location.href = '/login';
                }, 1500);
            } else {
                throw new Error(result.error);
            }
        } catch (e) {
            err.classList.remove('hidden');
            document.getElementById('errorText').textContent = e.message || 'Update failed.';
            btn.disabled = false;
            text.textContent = 'Finalize Recovery';
            spin.classList.add('hidden');
        }
    });

    document.getElementById('otp').addEventListener('input', function() {
        this.value = this.value.replace(/\\\\D/g, '');
    });
</script>
` }) %>
