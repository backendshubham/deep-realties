<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[40vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1448630360428-65456885c650?auto=format&fit=crop&q=80" 
             alt="Luxury Estates" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-r from-lux-midnight via-lux-midnight/80 to-transparent dark:from-black dark:via-black/90 dark:to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="max-w-3xl">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
                EXCLUSIVE LISTINGS
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
                Discover Your <br/>
                <span class="text-emerald-400">Dream Property</span>
            </h1>
            
            <p class="text-lg md:text-xl text-white/70 max-w-2xl leading-relaxed">
                Explore our curated collection of verified premium properties, from luxury villas to strategic investment plots.
            </p>
        </div>
    </div>
</section>

<style>
    @media (min-width: 1024px) {
        section#filterSection {
            width: 20% !important;
            max-width: 20% !important;
            flex: 0 0 20% !important;
        }

        section#filterSection + section {
            width: 80% !important;
            flex: 0 0 80% !important;
        }

        #propertiesContentScroll {
            height: 100%;
            overflow-y: auto;
        }
    }
</style>

<!-- Mobile Filter Toggle Button -->
<button onclick="toggleMobileFilters()" class="lg:hidden fixed bottom-6 right-6 z-[95] bg-emerald-600 text-white p-4 rounded-full shadow-[0_8px_30px_rgb(16,185,129,0.4)] hover:shadow-[0_8px_30px_rgb(16,185,129,0.6)] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center group" title="Filters">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
</button>

<!-- Mobile Filter Overlay -->
<div id="filterOverlay" class="fixed inset-0 bg-lux-midnight/40 backdrop-blur-md z-[100] hidden transition-opacity duration-500" onclick="toggleMobileFilters()"></div>
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 lg:flex lg:items-start lg:gap-8 lg:h-[calc(100vh-9rem)] lg:overflow-hidden">

<!-- Filter & Search Section -->
<section id="filterSection" class="fixed inset-y-0 right-0 z-[110] w-full max-w-sm bg-white dark:bg-lux-midnight shadow-2xl transform translate-x-full transition-transform duration-500 ease-in-out lg:static lg:w-1/5 lg:min-w-[260px] lg:max-w-none lg:bg-transparent lg:shadow-none lg:transform-none lg:z-30 p-6 lg:p-0 h-full lg:overflow-visible">
    <div class="h-full flex flex-col lg:block">
        
        <!-- Mobile Header inside Drawer -->
        <div class="flex items-center justify-between lg:hidden mb-8 pb-4 border-b border-gray-100 dark:border-white/5 sticky top-0 bg-white dark:bg-lux-midnight z-10 pt-2">
            <h3 class="text-xl font-display font-bold text-gray-900 dark:text-white">Refine Search</h3>
            <button onclick="toggleMobileFilters()" class="p-2 border border-gray-100 dark:border-white/10 rounded-full text-gray-400 hover:text-gray-600 dark:hover:text-white transition-colors bg-gray-50 dark:bg-white/5">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div class="flex flex-col gap-6 flex-1 lg:flex-none lg:glass-panel lg:rounded-3xl lg:border-gray-100 dark:lg:border-white/10 lg:p-6">
            <!-- Search Bar Search -->
            <div class="grid grid-cols-1 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">City</label>
                    <input type="text" id="searchCity" placeholder="Any City" 
                           class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Type</label>
                    <select id="searchPropertyType" class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all appearance-none">
                        <option value="">All Types</option>
                        <option value="flat">Flat</option>
                        <option value="house">House</option>
                        <option value="plot">Plot</option>
                        <option value="farmland">Farm Land</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Min Price (₹)</label>
                    <input type="number" id="searchMinPrice" placeholder="Min" 
                           class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Max Price (₹)</label>
                    <input type="number" id="searchMaxPrice" placeholder="Max" 
                           class="w-full px-5 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500">
                </div>
            </div>
            
            <div class="flex flex-col gap-4 mt-8 pt-6 border-t border-gray-100 dark:border-white/5 pb-2">
                <button onclick="applyFiltersAndClose()" class="w-full px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-bold transition-all shadow-lg shadow-emerald-500/20 flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    Apply Filters
                </button>
                <button onclick="clearFilters()" class="w-full px-5 py-4 bg-gray-50 lg:bg-white/5 text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-white/10 rounded-xl hover:bg-gray-100 dark:hover:bg-white/10 transition-all font-semibold">
                    Reset
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Main Inventory Section -->
<section class="py-16 lg:py-0 bg-gray-50 dark:bg-black/20 min-h-screen lg:w-4/5 lg:h-full">
    <div id="propertiesContentScroll" class="flex-1 lg:h-full lg:overflow-y-auto lg:pl-4 lg:pr-4">
        <div class="flex items-center justify-between mb-10">
            <h2 id="resultsCount" class="text-lg font-bold text-gray-900 dark:text-white">
                <span id="resultsNumber" class="text-emerald-500">0</span> Properties Available
            </h2>
            <div class="flex items-center space-x-2 text-sm text-gray-500">
                <span>Sort by:</span>
                <select class="bg-transparent font-bold text-emerald-500 focus:ring-0 border-none cursor-pointer">
                    <option>Latest First</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                </select>
            </div>
        </div>

        <!-- Grid -->
        <div id="propertiesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 p-2 lg:p-4">
            <!-- Populate via JS -->
        </div>

        <div id="loadingState" class="hidden text-center py-40">
            <div class="inline-loader-spinner mx-auto mb-4 border-t-emerald-500"></div>
            <p class="text-gray-500 dark:text-gray-400 font-medium">Scanning premium inventory...</p>
        </div>

        <div id="emptyState" class="hidden text-center py-40 glass-panel rounded-[2rem]">
            <div class="w-20 h-20 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">No matching properties</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-8">Try adjusting your filters to find more options.</p>
            <button onclick="clearFilters()" class="px-8 py-3 bg-emerald-600 text-white rounded-xl">Clear All Filters</button>
        </div>

        <!-- Pagination -->
        <div id="pagination" class="hidden mt-10 flex flex-wrap justify-center items-center gap-2">
        </div>
</div>
    </div>
</section>

<script>
    let currentPage = 1;
    let totalPages = 1;
    let activeFilters = {};
    const limit = 10;

    function renderPropertiesCards(properties) {
        return properties.map(prop => \`
                    <div class="glass-panel group rounded-[2rem] overflow-hidden hover:border-emerald-500/50 transition-all duration-500">
                        <div class="relative h-72 overflow-hidden">
                            <img src="\${prop.images && prop.images[0] || 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80'}" 
                                 class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-4 left-4 bg-lux-midnight/40 backdrop-blur-md text-white text-[10px] font-bold px-4 py-2 rounded-full uppercase tracking-widest border border-white/10">
                                \${prop.property_type.toUpperCase()}
                            </div>
                        </div>
                        <div class="p-8">
                            <div class="flex items-center text-emerald-500 text-[10px] font-bold mb-3 uppercase tracking-[0.2em]">
                                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"></path></svg>
                                \${prop.locality}, \${prop.city}
                            </div>
                            <h3 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-6 line-clamp-1 group-hover:text-emerald-500 transition-colors">
                                \${prop.title}
                            </h3>
                            <div class="flex items-center gap-6 mb-8 text-sm text-gray-500">
                                \${prop.bedrooms ? \`
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 mr-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                                    \${prop.bedrooms} BDS
                                </div>\` : ''}
                                <div class="flex items-center">
                                    <svg class="w-5 h-5 mr-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                                    \${prop.area_sqft || '—'} SQFT
                                </div>
                            </div>
                            <div class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-white/10">
                                <div class="text-3xl font-display font-bold text-gray-900 dark:text-white">
                                    ₹\${prop.price.toLocaleString()}
                                </div>
                                <a href="/properties/\${prop.id}" class="w-12 h-12 rounded-full border border-gray-200 dark:border-white/10 flex items-center justify-center group-hover:bg-emerald-500 group-hover:border-emerald-500 transition-all transform group-hover:rotate-45">
                                    <svg class="w-6 h-6 dark:text-white group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                \`).join('');
    }

    function renderPaginationControls() {
        const pagination = document.getElementById('pagination');
        if (totalPages > 1) {
            pagination.classList.remove('hidden');
            const startPage = Math.max(1, currentPage - 2);
            const endPage = Math.min(totalPages, currentPage + 2);
            let html = '';

            html += \`<button onclick="changePropertiesPage(\${currentPage - 1})" class="px-3 py-2 rounded-lg border border-gray-200 dark:border-white/10 text-sm font-semibold \${currentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:border-emerald-500'}" \${currentPage === 1 ? 'disabled' : ''}>Prev</button>\`;

            for (let i = startPage; i <= endPage; i++) {
                html += \`<button onclick="changePropertiesPage(\${i})" class="w-10 h-10 rounded-lg text-sm font-semibold transition-all \${i === currentPage ? 'bg-emerald-600 text-white' : 'border border-gray-200 dark:border-white/10 hover:border-emerald-500'}">\${i}</button>\`;
            }

            html += \`<button onclick="changePropertiesPage(\${currentPage + 1})" class="px-3 py-2 rounded-lg border border-gray-200 dark:border-white/10 text-sm font-semibold \${currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : 'hover:border-emerald-500'}" \${currentPage === totalPages ? 'disabled' : ''}>Next</button>\`;
            pagination.innerHTML = html;
        } else {
            pagination.classList.add('hidden');
            pagination.innerHTML = '';
        }
    }

    async function loadProperties(filters = activeFilters, page = 1) {
        const grid = document.getElementById('propertiesGrid');
        const loading = document.getElementById('loadingState');
        const empty = document.getElementById('emptyState');
        const pagination = document.getElementById('pagination');
        
        grid.innerHTML = '';
        grid.classList.add('hidden');
        loading.classList.remove('hidden');
        empty.classList.add('hidden');
        pagination.classList.add('hidden');
        
        try {
            const params = new URLSearchParams(filters);
            params.append('status', 'approved');
            params.append('page', page);
            params.append('limit', limit);
            
            const response = await fetch('/api/properties?' + params.toString());
            const data = await response.json();
            
            loading.classList.add('hidden');
            const total = data.pagination ? data.pagination.total : (data.properties ? data.properties.length : 0);
            document.getElementById('resultsNumber').textContent = total;
            totalPages = data.pagination ? data.pagination.pages : 1;
            currentPage = page;
            
            if (data.properties && data.properties.length > 0) {
                grid.classList.remove('hidden');
                grid.innerHTML = renderPropertiesCards(data.properties);
                renderPaginationControls();
            } else {
                empty.classList.remove('hidden');
            }
        } catch (error) {
            console.error(error);
            loading.classList.add('hidden');
            empty.classList.remove('hidden');
        }
    }

    function getFilters() {
        return {
            city: document.getElementById('searchCity').value,
            property_type: document.getElementById('searchPropertyType').value,
            min_price: document.getElementById('searchMinPrice').value,
            max_price: document.getElementById('searchMaxPrice').value
        };
    }

    function searchProperties() {
        activeFilters = getFilters();
        loadProperties(activeFilters, 1);
    }

    function clearFilters() {
        document.getElementById('searchCity').value = '';
        document.getElementById('searchPropertyType').value = '';
        document.getElementById('searchMinPrice').value = '';
        document.getElementById('searchMaxPrice').value = '';
        activeFilters = {};
        loadProperties(activeFilters, 1);
    }

    function changePropertiesPage(page) {
        if (page < 1 || page > totalPages || page === currentPage) return;
        loadProperties(activeFilters, page);
        const contentScroll = document.getElementById('propertiesContentScroll');
        if (contentScroll) {
            contentScroll.scrollTo({ top: 0, behavior: 'smooth' });
        }
    }
    
    function toggleMobileFilters() {
        if (window.innerWidth >= 1024) return;
        const filterSection = document.getElementById('filterSection');
        const filterOverlay = document.getElementById('filterOverlay');
        const isHidden = filterSection.classList.contains('translate-x-full');
        
        if (isHidden) {
            filterSection.classList.remove('translate-x-full');
            filterOverlay.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        } else {
            filterSection.classList.add('translate-x-full');
            filterOverlay.classList.add('hidden');
            document.body.style.overflow = '';
        }
    }
    
    function applyFiltersAndClose() {
        searchProperties();
        if (window.innerWidth < 1024) {
            toggleMobileFilters();
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadProperties(activeFilters, 1);
    });
</script>
` }) %>
