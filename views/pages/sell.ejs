<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[60vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80" 
             alt="Luxury Property" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-r from-lux-midnight via-lux-midnight/80 to-transparent dark:from-black dark:via-black/90 dark:to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="max-w-3xl">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
                PREMIUM LISTING CONCIERGE
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
                Sell Your Property <br/>
                <span class="text-emerald-400">At Premium Value</span>
            </h1>
            
            <p class="text-lg md:text-xl text-white/70 mb-10 max-w-2xl leading-relaxed">
                Connect with serious buyers and get the best market value for your property through our exclusive luxury network.
            </p>
            
            <div class="flex flex-wrap gap-4">
                <a href="#sellForm" class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl font-semibold transition-all shadow-lg shadow-emerald-900/20 flex items-center group">
                    Start Listing Now
                    <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
                <a href="/contact" class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white rounded-xl font-semibold backdrop-blur-md border border-white/10 transition-all">
                    Consult Agent
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Stats & Trust Section -->
<section class="py-20 relative bg-white dark:bg-lux-midnight overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <div class="absolute -top-10 -left-10 w-40 h-40 bg-emerald-500/10 rounded-full blur-3xl"></div>
                <h2 class="text-4xl font-display font-bold text-gray-900 dark:text-white mb-8">
                    Why Choose <span class="text-emerald-500">DeepRealties</span> <br/>To Sell Your Property?
                </h2>
                <div class="space-y-6">
                    <div class="flex items-start p-6 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 hover:border-emerald-500/50 transition-colors">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center text-emerald-500 mr-4 flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Verified Network</h3>
                            <p class="text-gray-600 dark:text-gray-400">Access our exclusive database of pre-verified buyers looking for premium opportunities.</p>
                        </div>
                    </div>
                    <div class="flex items-start p-6 rounded-2xl bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 hover:border-emerald-500/50 transition-colors">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/20 flex items-center justify-center text-emerald-500 mr-4 flex-shrink-0">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Maximum ROI</h3>
                            <p class="text-gray-600 dark:text-gray-400">Our data-driven pricing strategies ensure you get the absolute best value for your asset.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="grid grid-cols-2 gap-6">
                <div class="glass-panel p-8 text-center rounded-3xl">
                    <div class="text-4xl font-bold text-emerald-500 mb-2">500+</div>
                    <div class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Trusted Sales</div>
                </div>
                <div class="glass-panel p-8 text-center rounded-3xl mt-12">
                    <div class="text-4xl font-bold text-emerald-500 mb-2">₹100Cr+</div>
                    <div class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Inventory Sold</div>
                </div>
                <div class="glass-panel p-8 text-center rounded-3xl">
                    <div class="text-4xl font-bold text-emerald-500 mb-2">98%</div>
                    <div class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Success Rate</div>
                </div>
                <div class="glass-panel p-8 text-center rounded-3xl mt-12">
                    <div class="text-4xl font-bold text-emerald-500 mb-2">15 Days</div>
                    <div class="text-sm uppercase tracking-widest text-gray-500 dark:text-gray-400">Avg. Sale Time</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Listing Form Section -->
<section id="sellSection" class="py-24 bg-gray-50 dark:bg-black/40 relative">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-display font-bold text-gray-900 dark:text-white mb-4">List Your Property</h2>
            <p class="text-gray-600 dark:text-gray-400">Fill in the details below to start your premium selling journey.</p>
        </div>

        <!-- Success Message -->
        <div id="successMessage" class="hidden glass-panel border-emerald-500/50 p-12 text-center rounded-3xl mb-12">
            <div class="w-20 h-20 bg-emerald-500 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-emerald-500/20">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Listing Received!</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
                Your property details have been submitted successfully. Our concierge team will review and contact you within 24 hours.
            </p>
            <button onclick="resetForm()" class="px-8 py-3 bg-emerald-600 text-white rounded-xl hover:bg-emerald-700 transition-colors">
                List Another Property
            </button>
        </div>

        <div id="sellFormContainer" class="glass-panel rounded-[2rem] p-8 md:p-12 border-white/10 shadow-2xl relative overflow-hidden">
            <!-- Form Background Accent -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/5 blur-[80px] -mr-32 -mt-32"></div>
            
            <form id="sellForm" class="space-y-12 relative z-10">
                <!-- Property Type Selection -->
                <div class="space-y-6">
                    <label class="block text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-widest">Select Property Type</label>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="flat" class="peer sr-only" checked>
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-50:peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">Flat</span>
                            </div>
                        </label>
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="house" class="peer sr-only">
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-50:peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">House</span>
                            </div>
                        </label>
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="plot" class="peer sr-only">
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-50:peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">Plot</span>
                            </div>
                        </label>
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="farmland" class="peer sr-only">
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-50:peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">Farmland</span>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Basic Information -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Listing Title</label>
                        <input type="text" name="title" required placeholder="e.g. Luxurious 4BHK Villa in Premium Colony"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>
                    
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Description</label>
                        <textarea name="description" rows="4" required placeholder="Describe the key features, amenities and selling points..."
                                  class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all"></textarea>
                    </div>

                    <div id="priceGroup">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Total Price (₹)</label>
                        <input type="number" name="price" placeholder="e.g. 7500000"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>

                    <div id="pricePerBighaGroup" class="hidden">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Price Per Bigha (₹)</label>
                        <input type="number" name="price_per_bigha" placeholder="e.g. 1500000"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>

                    <div id="areaSqftGroup">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Total Area (Sq.Ft)</label>
                        <input type="number" name="area_sqft" placeholder="e.g. 1500"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>

                    <!-- Plot Specific Fields -->
                    <div id="plotFields" class="hidden md:col-span-2">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Total Area (Sq.Ft)</label>
                                <input type="number" name="plot_total_area" placeholder="e.g. 1200"
                                       class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Length (ft)</label>
                                <input type="number" name="plot_length" placeholder="e.g. 40"
                                       class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Width (ft)</label>
                                <input type="number" name="plot_width" placeholder="e.g. 30"
                                       class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                            </div>
                        </div>
                    </div>

                    <!-- Farmland Specific Fields -->
                    <div id="farmlandFields" class="hidden md:col-span-2">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Area in Bigha</label>
                                <input type="number" step="0.01" name="farmland_bigha" placeholder="e.g. 2.5"
                                       class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Area in Acre</label>
                                <input type="number" step="0.01" name="farmland_acre" placeholder="e.g. 1.2"
                                       class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">No. of Plots (If Any)</label>
                                <input type="number" name="number_of_plots" placeholder="e.g. 1"
                                       class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                            </div>
                        </div>
                    </div>

                    <!-- Additional Details -->
                    <div id="commonDetails" class="md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div id="bedroomGroup">
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Bedrooms</label>
                            <input type="number" name="bedrooms" placeholder="3"
                                   class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                        </div>
                        <div id="bathroomGroup">
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Bathrooms</label>
                            <input type="number" name="bathrooms" placeholder="2"
                                   class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                        </div>
                        <div id="floorGroup">
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Total Floors</label>
                            <input type="number" name="floors" placeholder="2"
                                   class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Property Facing</label>
                        <select name="facing" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all appearance-none">
                            <option value="">Select Direction</option>
                            <option value="North">North</option>
                            <option value="South">South</option>
                            <option value="East">East</option>
                            <option value="West">West</option>
                            <option value="North-East">North-East</option>
                            <option value="North-West">North-West</option>
                            <option value="South-East">South-East</option>
                            <option value="South-West">South-West</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Locality</label>
                        <input type="text" name="locality" required placeholder="e.g. Vijay Nagar"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">City</label>
                        <input type="text" name="city" required placeholder="e.g. Indore"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">State</label>
                        <input type="text" name="state" required placeholder="e.g. Madhya Pradesh"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>
                </div>

                <!-- Image Upload -->
                <div class="space-y-6">
                    <label class="block text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-widest">Property Images (Max 5)</label>
                    <div id="imageDropZone" class="relative group">
                        <input type="file" id="propertyImages" name="images" multiple accept="image/*" class="sr-only">
                        <div class="border-2 border-dashed border-gray-200 dark:border-white/10 rounded-3xl p-12 text-center transition-all group-hover:border-emerald-500/50 group-hover:bg-emerald-500/5 cursor-pointer">
                            <div id="dropZoneContent">
                                <div class="w-16 h-16 rounded-full bg-emerald-500/10 flex items-center justify-center mx-auto mb-4 text-emerald-500">
                                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                    </svg>
                                </div>
                                <p class="text-gray-900 dark:text-white font-bold text-lg mb-1">Click or drag images to upload</p>
                                <p class="text-gray-500 dark:text-gray-400">High quality photos attract more buyers</p>
                            </div>
                            <div id="dropZoneActive" class="hidden">
                                <p class="text-emerald-500 font-bold text-xl">Drop images here</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Previews -->
                    <div id="imagePreviews" class="grid grid-cols-2 md:grid-cols-5 gap-4"></div>
                </div>

                <!-- Contact Information -->
                <div class="space-y-8 pt-8 border-t border-gray-100 dark:border-white/10">
                    <div id="loggedInUserInfo" class="hidden p-4 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm">
                        <div class="flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span>Your contact information will be pre-filled from your account.</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Full Name</label>
                            <input type="text" id="full_name" name="full_name" required placeholder="Your Name"
                                   class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Email Address</label>
                            <input type="email" id="email" name="email" required placeholder="email@example.com"
                                   class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Phone Number</label>
                            <input type="tel" id="phone" name="phone" required placeholder="+91 98765 43210"
                                   class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                        </div>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="pt-8">
                    <button type="submit" 
                            class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-lg rounded-2xl transition-all shadow-xl shadow-emerald-500/20 flex items-center justify-center group">
                        <span>List Property Now</span>
                        <svg class="w-6 h-6 ml-2 transform group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </button>
                    <p class="text-center text-gray-500 dark:text-gray-400 mt-4 text-sm">
                        By listing, you agree to our <a href="#" class="text-emerald-500 hover:underline">Terms of Service</a> and <a href="#" class="text-emerald-500 hover:underline">Privacy Policy</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- Empty state hidden container -->
<div id="emptyCard" class="hidden"></div>

<script>
    // Property field toggling logic
    function togglePropertyFields() {
        const typeEl = document.querySelector('input[name="property_type"]:checked');
        if (!typeEl) return;
        const type = typeEl.value;
        const commonDetails = document.getElementById('commonDetails');
        const bedroomGroup = document.getElementById('bedroomGroup');
        const bathroomGroup = document.getElementById('bathroomGroup');
        const floorGroup = document.getElementById('floorGroup');
        const plotFields = document.getElementById('plotFields');
        const farmlandFields = document.getElementById('farmlandFields');
        const areaSqftGroup = document.getElementById('areaSqftGroup');
        const priceGroup = document.getElementById('priceGroup');
        const pricePerBighaGroup = document.getElementById('pricePerBighaGroup');

        // Reset all
        [commonDetails, bedroomGroup, bathroomGroup, floorGroup, plotFields, farmlandFields, areaSqftGroup, priceGroup, pricePerBighaGroup].forEach(el => {
            if (el) el.classList.add('hidden');
        });

        if (type === 'flat' || type === 'house') {
            commonDetails.classList.remove('hidden');
            bedroomGroup.classList.remove('hidden');
            bathroomGroup.classList.remove('hidden');
            floorGroup.classList.remove('hidden');
            areaSqftGroup.classList.remove('hidden');
            priceGroup.classList.remove('hidden');
        } else if (type === 'plot') {
            plotFields.classList.remove('hidden');
            priceGroup.classList.remove('hidden');
        } else if (type === 'farmland') {
            farmlandFields.classList.remove('hidden');
            priceGroup.classList.remove('hidden');
            pricePerBighaGroup.classList.remove('hidden');
        }
    }

    // Image handling logic
    let selectedFiles = [];
    const imageInput = document.getElementById('propertyImages');
    const imagePreviews = document.getElementById('imagePreviews');
    const dropZone = document.getElementById('imageDropZone');
    const dropZoneContent = document.getElementById('dropZoneContent');
    const dropZoneActive = document.getElementById('dropZoneActive');

    if (dropZone) {
        dropZone.onclick = () => imageInput.click();
        
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZoneActive.classList.remove('hidden');
            dropZoneContent.classList.add('hidden');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZoneActive.classList.add('hidden');
            dropZoneContent.classList.remove('hidden');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZoneActive.classList.add('hidden');
            dropZoneContent.classList.remove('hidden');
            handleFiles(e.dataTransfer.files);
        });

        imageInput.onchange = (e) => handleFiles(e.target.files);
    }

    function handleFiles(files) {
        const fileList = Array.from(files);
        if (selectedFiles.length + fileList.length > 5) {
            showError('You can only upload up to 5 images.');
            return;
        }

        fileList.forEach(file => {
            if (!file.type.startsWith('image/')) return;
            selectedFiles.push(file);
            
            const reader = new FileReader();
            reader.onload = (e) => {
                const div = document.createElement('div');
                div.className = 'relative aspect-square rounded-xl overflow-hidden group';
                div.innerHTML = \\\`
                    <img src="\\\${e.target.result}" class="w-full h-full object-cover">
                    <button type="button" class="absolute top-2 right-2 p-1 bg-red-500 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity" onclick="removeImage(\\\${selectedFiles.length - 1})">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                \\\`;
                imagePreviews.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
        updateFileInput();
    }

    function removeImage(index) {
        selectedFiles.splice(index, 1);
        renderPreviews();
        updateFileInput();
    }

    function renderPreviews() {
        imagePreviews.innerHTML = '';
        selectedFiles.forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                const div = document.createElement('div');
                div.className = 'relative aspect-square rounded-xl overflow-hidden group';
                div.innerHTML = \\\`
                    <img src="\\\${e.target.result}" class="w-full h-full object-cover">
                    <button type="button" class="absolute top-2 right-2 p-1 bg-red-500 text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity" onclick="removeImage(\\\${index})">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                \\\`;
                imagePreviews.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
    }

    function updateFileInput() {
        const dataTransfer = new DataTransfer();
        selectedFiles.forEach(file => dataTransfer.items.add(file));
        imageInput.files = dataTransfer.files;
    }

    // Load user information
    async function loadUserInfo() {
        const token = localStorage.getItem('token');
        if (!token) return;
        
        try {
            const response = await fetch('/api/auth/me', {
                headers: { 'Authorization': 'Bearer ' + token }
            });
            if (response.ok) {
                const data = await response.json();
                if (data.user) {
                    const infoBox = document.getElementById('loggedInUserInfo');
                    if (infoBox) infoBox.classList.remove('hidden');
                    document.getElementById('full_name').value = data.user.full_name || '';
                    document.getElementById('email').value = data.user.email || '';
                    document.getElementById('phone').value = data.user.phone || '';
                }
            }
        } catch (e) { console.error('Error loading user info:', e); }
    }

    function resetForm() {
        document.getElementById('successMessage').classList.add('hidden');
        document.getElementById('sellFormContainer').style.display = 'block';
        document.getElementById('sellForm').reset();
        selectedFiles = [];
        imagePreviews.innerHTML = '';
        togglePropertyFields();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadUserInfo();
        const radios = document.querySelectorAll('input[name="property_type"]');
        radios.forEach(r => r.addEventListener('change', togglePropertyFields));
        togglePropertyFields();
    });

    // Form Submission
    document.getElementById('sellForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = e.target.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        
        try {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="flex items-center"><svg class="animate-spin h-5 w-5 mr-3 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Processing...</span>';

            const formData = new FormData(e.target);
            const data = {};
            formData.forEach((value, key) => {
                if (key === 'images') return;
                if (key === 'amenities') {
                    data[key] = data[key] || [];
                    data[key].push(value);
                    return;
                }
                const numValue = parseFloat(value);
                data[key] = isNaN(numValue) || key === 'phone' ? value : numValue;
            });

            // 1. Upload Images
            const imageFormData = new FormData();
            selectedFiles.forEach(file => imageFormData.append('images', file));
            
            const uploadRes = await fetch('/api/upload/property-images', {
                method: 'POST',
                headers: localStorage.getItem('token') ? { 'Authorization': 'Bearer ' + localStorage.getItem('token') } : {},
                body: imageFormData
            });

            if (!uploadRes.ok) throw new Error('Image upload failed');
            const uploadData = await uploadRes.json();
            data.images = uploadData.images;

            // 2. Submit Property
            const token = localStorage.getItem('token');
            const res = await fetch('/api/properties', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...(token && { 'Authorization': 'Bearer ' + token })
                },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                const result = await res.json();
                document.getElementById('sellFormContainer').style.display = 'none';
                document.getElementById('successMessage').classList.remove('hidden');
                window.scrollTo({ top: 0, behavior: 'smooth' });
                if (result.property && result.property.id) {
                    setTimeout(() => window.location.href = '/properties/' + result.property.id, 3000);
                }
            } else {
                const error = await res.json();
                showError(error.error || 'Failed to submit property');
            }
        } catch (error) {
            console.error(error);
            showError('An unexpected error occurred. Please try again.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });

    function showError(msg) {
        if (window.showError) window.showError(msg);
        else alert(msg);
    }
</script>
` }) %>
