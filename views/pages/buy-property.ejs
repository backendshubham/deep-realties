        } else if (formData.get('property_type') === 'farmland') {
            // For Farm Land: show budget per bigha, bigha, acre
            if (formData.get('min_budget_per_bigha') || formData.get('max_budget_per_bigha')) {
                const minPerBigha = formData.get('min_budget_per_bigha') ? parseFloat(formData.get('min_budget_per_bigha')).toLocaleString() : 'Not specified';
                const maxPerBigha = formData.get('max_budget_per_bigha') ? parseFloat(formData.get('max_budget_per_bigha')).toLocaleString() : 'Not specified';
                message += 'Budget Range per bigha: ₹' + minPerBigha + ' - ₹' + maxPerBigha + String.fromCharCode(10);
