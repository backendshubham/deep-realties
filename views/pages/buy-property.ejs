    // Add event listeners to property type radio buttons
    document.addEventListener('DOMContentLoaded', function() {
        // Use event delegation on the form to catch all radio button changes
        const buyForm = document.getElementById('buyForm');
        if (buyForm) {
            buyForm.addEventListener('change', function(e) {
                if (e.target.name === 'property_type' && e.target.type === 'radio') {
                    window.togglePropertyFields();
                }
            });
            
            buyForm.addEventListener('click', function(e) {
                if (e.target.name === 'property_type' && e.target.type === 'radio') {
                    setTimeout(window.togglePropertyFields, 10);
                }
            });
        }
        
        // Also add direct listeners to radio buttons
        const propertyTypeRadios = document.querySelectorAll('input[name="property_type"]');
        propertyTypeRadios.forEach(radio => {
            radio.addEventListener('change', window.togglePropertyFields);
        });
        
        // Initialize on page load
        setTimeout(function() {
            window.togglePropertyFields();
        }, 100);
        
        // Form submission handler (reuse buyForm from above)
        if (buyForm) {
            buyForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(e.target);
                
                // Validate required fields based on property type
                const propertyType = formData.get('property_type');
                if (propertyType === 'plot') {
                    // For plot: require per sqft budget fields
                    if (!formData.get('min_budget_per_sqft') || !formData.get('max_budget_per_sqft')) {
                        if (typeof window.showError === 'function') {
                            window.showError('Please provide both minimum and maximum budget per square foot for plot.');
                        } else {
                            alert('Please provide both minimum and maximum budget per square foot for plot.');
                        }
                        return;
                    }
                } else if (propertyType === 'farmland') {
                    // For farmland: require per bigha budget fields and at least one of bigha/acre
                    if (!formData.get('min_budget_per_bigha') || !formData.get('max_budget_per_bigha')) {
                        if (typeof window.showError === 'function') {
                            window.showError('Please provide both minimum and maximum budget per bigha for farm land.');
