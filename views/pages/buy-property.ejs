<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[50vh] flex items-center overflow-hidden bg-white dark:bg-lux-midnight transition-colors">
    <!-- Hero Background Image with Theme-Aware Overlay -->
    <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1600585154340-be6199f7d009?auto=format&fit=crop&q=80&w=1920" 
             alt="Modern Mansion" 
             class="w-full h-full object-cover opacity-20 dark:opacity-40">
        <div class="absolute inset-0 bg-gradient-to-b from-white/80 dark:from-lux-midnight/80 via-white/50 dark:via-lux-midnight/50 to-white dark:to-lux-midnight"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full pt-20 pb-12 text-center lg:text-left">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-8">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
            <span class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest">Find Your Sanctuary</span>
        </div>
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold text-slate-900 dark:text-white mb-6 leading-tight italic">
            Acquire More Than <br><span class="text-emerald-600">A Property.</span>
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-gray-400 max-w-2xl leading-relaxed mb-8">
            Our curators hand-select only the finest estates in Indore's most prestigious postcodes. Your journey to exceptional living begins here.
        </p>
    </div>
</section>

<!-- Informative Content Section -->
<section class="py-24 bg-white dark:bg-lux-midnight relative overflow-hidden">
    <!-- Abstract Background Shape -->
    <div class="absolute top-0 right-0 w-1/2 h-1/2 bg-emerald-50 dark:bg-emerald-900/5 rounded-bl-full -z-0"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-20 items-center mb-24">
            <div>
                <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-8 leading-tight">
                    A Curated Buying <span class="text-emerald-600">Experience</span>
                </h2>
                <div class="space-y-6 text-lg text-slate-600 dark:text-gray-400 leading-relaxed">
                    <p>
                        Searching for a new home shouldn't be a chore. We provide a bespoke acquisition service that prioritizes your time and your taste.
                    </p>
                    <p>
                        From sweeping agricultural estates to contemporary penthouses in the heart of the city, we offer access to the Most exclusive off-market opportunities in Indore.
                    </p>
                </div>
            </div>

            <div class="glass-panel p-10 rounded-3xl relative">
                <div class="absolute -top-6 -right-6 w-20 h-20 bg-emerald-600 rounded-2xl flex items-center justify-center shadow-xl transform rotate-12">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">The Acquisition Journey</h3>
                <div class="space-y-8">
                    <div class="flex gap-6">
                        <div class="text-3xl font-bold text-emerald-600/30">01</div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Requirement Brief</h4>
                            <p class="text-slate-600 dark:text-gray-400 text-sm">Define your vision. Budget, location, and must-have lifestyle amenities.</p>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="text-3xl font-bold text-emerald-600/30">02</div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Concierge Search</h4>
                            <p class="text-slate-600 dark:text-gray-400 text-sm">We scour private listings and off-market gems to find your perfect match.</p>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="text-3xl font-bold text-emerald-600/30">03</div>
                        <div>
                            <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Exclusive Preview</h4>
                            <p class="text-slate-600 dark:text-gray-400 text-sm">Receive a personalized portfolio of verified properties ready for private viewings.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
            <div class="p-8 rounded-2xl bg-slate-50 dark:bg-white/5 border border-slate-100 dark:border-white/10 hover:border-emerald-500/50 transition-all">
                <div class="w-14 h-14 bg-emerald-600/10 rounded-xl flex items-center justify-center mb-6">
                    <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Elite Verification</h3>
                <p class="text-slate-600 dark:text-gray-400 text-sm leading-relaxed">
                    Every property undergoes a rigorous 50-point checklist covering legal titles, structural integrity, and architectural value.
                </p>
            </div>
            <div class="p-8 rounded-2xl bg-slate-50 dark:bg-white/5 border border-slate-100 dark:border-white/10 hover:border-emerald-500/50 transition-all">
                <div class="w-14 h-14 bg-emerald-600/10 rounded-xl flex items-center justify-center mb-6">
                    <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Transparent Pricing</h3>
                <p class="text-slate-600 dark:text-gray-400 text-sm leading-relaxed">
                    No hidden fees. We provide clear, market-justified valuations ensuring you invest your capital with absolute confidence.
                </p>
            </div>
            <div class="p-8 rounded-2xl bg-slate-50 dark:bg-white/5 border border-slate-100 dark:border-white/10 hover:border-emerald-500/50 transition-all">
                <div class="w-14 h-14 bg-emerald-600/10 rounded-xl flex items-center justify-center mb-6">
                    <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Lifetime Advisory</h3>
                <p class="text-slate-600 dark:text-gray-400 text-sm leading-relaxed">
                    Our relationship doesn't end at the closing table. We provide ongoing portfolio management and property tax advisory.
                </p>
            </div>
        </div>

        <div class="bg-slate-900 text-white rounded-3xl p-12 relative overflow-hidden group">
            <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&q=80&w=1920')] opacity-10 bg-cover bg-center group-hover:scale-105 transition-transform duration-700"></div>
            <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
                <div>
                    <h3 class="text-3xl font-bold mb-6">Explore the Collection</h3>
                    <p class="text-gray-400 mb-8 leading-relaxed">
                        From sprawling villas to modern high-rises, explore our full database of properties or share your specific requirements below.
                    </p>
                    <a href="/properties" class="inline-flex items-center px-8 py-4 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl font-bold transition-all hover:scale-105">
                        Browse Full Database
                        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div class="p-6 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 text-center">
                        <div class="text-3xl font-bold text-emerald-400 mb-1">500+</div>
                        <div class="text-xs font-bold uppercase tracking-widest text-gray-400">Listings</div>
                    </div>
                    <div class="p-6 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 text-center">
                        <div class="text-3xl font-bold text-emerald-400 mb-1">12+</div>
                        <div class="text-xs font-bold uppercase tracking-widest text-gray-400">Localities</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Form Section -->
<section class="py-24 bg-white dark:bg-lux-midnight border-t border-slate-100 dark:border-white/5">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-bold text-slate-900 dark:text-white mb-4">Concierge Request</h2>
            <p class="text-slate-600 dark:text-gray-400">Submit your bespoke requirements and let our curators find your match.</p>
        </div>

        <!-- Success Message -->
        <div id="successMessage" class="hidden glass-panel border-emerald-500/50 p-12 text-center rounded-3xl animate-reveal">
            <div class="w-20 h-20 bg-emerald-600/20 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4">Request Transmitted</h2>
            <p class="text-slate-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
                Your private acquisition request has been received. One of our property curators will contact you within 24 hours.
            </p>
            <button onclick="resetForm()" class="px-8 py-3 bg-slate-900 dark:bg-white dark:text-slate-900 text-white rounded-xl font-bold transition-all hover:scale-105">
                Submit Another Request
            </button>
        </div>
        
        <div id="buyFormContainer" class="bg-gray-50 dark:bg-white/5 rounded-3xl p-8 sm:p-12 border border-slate-200 dark:border-white/10 shadow-2xl relative overflow-hidden">
            <!-- Branding Accent -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-600/10 rounded-bl-full"></div>

            <form id="buyForm" class="space-y-10 relative z-10">
                <!-- Property Type Selection -->
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-6">Desired Asset Type</label>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <label class="group cursor-pointer">
                            <input type="radio" name="property_type" value="plot" required class="hidden peer">
                            <div class="p-4 border-2 border-slate-200 dark:border-white/10 rounded-2xl transition-all group-hover:border-emerald-500 peer-checked:border-emerald-600 peer-checked:bg-emerald-600/5 flex flex-col items-center gap-3">
                                <svg class="w-8 h-8 text-slate-400 peer-checked:text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path></svg>
                                <span class="text-xs font-bold text-slate-500 dark:text-gray-400 uppercase tracking-tighter">Plot</span>
                            </div>
                        </label>
                        <label class="group cursor-pointer">
                            <input type="radio" name="property_type" value="flat" required class="hidden peer">
                            <div class="p-4 border-2 border-slate-200 dark:border-white/10 rounded-2xl transition-all group-hover:border-emerald-500 peer-checked:border-emerald-600 peer-checked:bg-emerald-600/5 flex flex-col items-center gap-3">
                                <svg class="w-8 h-8 text-slate-400 peer-checked:text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                                <span class="text-xs font-bold text-slate-500 dark:text-gray-400 uppercase tracking-tighter">Apartment</span>
                            </div>
                        </label>
                        <label class="group cursor-pointer">
                            <input type="radio" name="property_type" value="house" required class="hidden peer">
                            <div class="p-4 border-2 border-slate-200 dark:border-white/10 rounded-2xl transition-all group-hover:border-emerald-500 peer-checked:border-emerald-600 peer-checked:bg-emerald-600/5 flex flex-col items-center gap-3">
                                <svg class="w-8 h-8 text-slate-400 peer-checked:text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                                <span class="text-xs font-bold text-slate-500 dark:text-gray-400 uppercase tracking-tighter">Villa</span>
                            </div>
                        </label>
                        <label class="group cursor-pointer">
                            <input type="radio" name="property_type" value="farmland" required class="hidden peer">
                            <div class="p-4 border-2 border-slate-200 dark:border-white/10 rounded-2xl transition-all group-hover:border-emerald-500 peer-checked:border-emerald-600 peer-checked:bg-emerald-600/5 flex flex-col items-center gap-3">
                                <svg class="w-8 h-8 text-slate-400 peer-checked:text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                <span class="text-xs font-bold text-slate-500 dark:text-gray-400 uppercase tracking-tighter">Estate</span>
                            </div>
                        </label>
                    </div>
                </div>
                
                <!-- Location -->
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Prime Location Details</label>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <input type="text" name="city" required placeholder="City (e.g. Indore)"
                                   class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none">
                        </div>
                        <div>
                            <input type="text" name="state" required placeholder="State (e.g. MP)"
                                   class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none">
                        </div>
                        <div>
                            <input type="text" name="locality" placeholder="Preferred Locality"
                                   class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none">
                        </div>
                    </div>
                </div>
                
                <!-- Budget Range -->
                <div id="regularBudgetFields" class="animate-reveal">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Investment Scale</label>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400">₹</span>
                            <input type="number" name="min_budget" placeholder="Min Investment" min="0"
                                   class="w-full pl-10 pr-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
                        </div>
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400">₹</span>
                            <input type="number" name="max_budget" placeholder="Max Investment" min="0"
                                   class="w-full pl-10 pr-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white focus:ring-2 focus:ring-emerald-500 outline-none transition-all">
                        </div>
                    </div>
                </div>
                
                <!-- Property Details - Conditional Blocks Section -->
                <div id="plotFields" class="hidden animate-reveal">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Plot Specifications</label>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        <input type="number" name="plot_length" placeholder="Length (ft)" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                        <input type="number" name="plot_width" placeholder="Width (ft)" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                        <input type="number" name="plot_total_area" placeholder="Total Area (sqft)" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                    </div>
                </div>
                
                <div id="farmlandFields" class="hidden animate-reveal">
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Estate Dimensions</label>
                    <div class="grid grid-cols-2 gap-6">
                        <input type="number" name="farmland_bigha" placeholder="Bigha" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl dark:text-white outline-none">
                        <input type="number" name="farmland_acre" placeholder="Acre" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl dark:text-white outline-none">
                    </div>
                </div>
                
                <div id="otherPropertyFields" class="animate-reveal">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <select name="bedrooms" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-600 dark:text-gray-400 outline-none">
                                <option value="">Residence Size (BHK)</option>
                                <option value="1">1 BHK</option>
                                <option value="2">2 BHK</option>
                                <option value="3">3 BHK</option>
                                <option value="4">4 BHK</option>
                                <option value="5">5+ BHK</option>
                            </select>
                        </div>
                        <input type="number" name="min_area" placeholder="Min Area (sqft)" class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                    </div>
                </div>
                
                <!-- Additional Requirements -->
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-4">Specific Requirements</label>
                    <textarea name="requirements" rows="4" placeholder="Mention preferred orientation, architectural style, or specific amenities like private pool, elevator, etc..."
                              class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none focus:ring-2 focus:ring-emerald-500 transition-all"></textarea>
                </div>
                
                <!-- Contact Information -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-slate-200 dark:border-white/10 pt-10">
                    <input type="text" name="full_name" required placeholder="Full Name"
                           class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                    <input type="email" name="email" required placeholder="Private Email Address"
                           class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                    <input type="tel" name="phone" required placeholder="Contact Number"
                           class="w-full px-5 py-4 bg-white dark:bg-white/5 border border-slate-200 dark:border-white/10 rounded-xl text-slate-900 dark:text-white outline-none">
                </div>
                
                <button type="submit" 
                        class="w-full py-5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl font-bold text-lg shadow-xl shadow-emerald-500/20 transition-all hover:scale-[1.02] active:scale-95">
                    Transmit Request
                </button>
            </form>
        </div>
    </div>
</section>


<script>
    function resetForm() {
        document.getElementById('successMessage').classList.add('hidden');
        document.getElementById('buyFormContainer').style.display = 'block';
        document.getElementById('buyForm').reset();
        if (window.togglePropertyFields) {
            window.togglePropertyFields(); // Reset field visibility
        }
        document.getElementById('buyForm').scrollIntoView({ behavior: 'smooth' });
    }
    
    // Make toggle function globally accessible
    window.togglePropertyFields = function() {
        const propertyType = document.querySelector('input[name="property_type"]:checked')?.value;
        const plotFields = document.getElementById('plotFields');
        const farmlandFields = document.getElementById('farmlandFields');
        const otherFields = document.getElementById('otherPropertyFields');
        const regularBudgetFields = document.getElementById('regularBudgetFields');
        const minBudgetInput = document.querySelector('input[name="min_budget"]');
