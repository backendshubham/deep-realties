                            window.showError('Please provide either Bigha or Acre for farm land.');
                        } else {
                            alert('Please provide either Bigha or Acre for farm land.');
                        }
                        return;
                    }
                } else {
                    // For other types (Flat, House): require regular budget fields
                    if (!formData.get('min_budget') || !formData.get('max_budget')) {
                        if (typeof window.showError === 'function') {
                            window.showError('Please provide both minimum and maximum budget.');
                        } else {
                            alert('Please provide both minimum and maximum budget.');
                        }
                        return;
                    }
                }
        
        // Build the message from form data
        let message = 'Property Requirement:' + String.fromCharCode(10) + String.fromCharCode(10);
        message += 'Property Type: ' + formData.get('property_type') + String.fromCharCode(10);
        message += 'Location: ' + (formData.get('locality') ? formData.get('locality') + ', ' : '') + formData.get('city') + ', ' + formData.get('state') + String.fromCharCode(10);
        
        // For Plot: show budget per sqft, length, width, total area
        if (formData.get('property_type') === 'plot') {
            if (formData.get('min_budget_per_sqft') || formData.get('max_budget_per_sqft')) {
                const minPerSqft = formData.get('min_budget_per_sqft') ? parseFloat(formData.get('min_budget_per_sqft')).toLocaleString() : 'Not specified';
                const maxPerSqft = formData.get('max_budget_per_sqft') ? parseFloat(formData.get('max_budget_per_sqft')).toLocaleString() : 'Not specified';
                message += 'Budget Range per sqft: ₹' + minPerSqft + ' - ₹' + maxPerSqft + String.fromCharCode(10);
            }
            if (formData.get('plot_length')) {
