        } else {
            // For other types (Flat, House): show regular budget, bedrooms, bathrooms, min area
            if (formData.get('min_budget') || formData.get('max_budget')) {
                const minBudget = formData.get('min_budget') ? parseInt(formData.get('min_budget')).toLocaleString() : 'Not specified';
                const maxBudget = formData.get('max_budget') ? parseInt(formData.get('max_budget')).toLocaleString() : 'Not specified';
