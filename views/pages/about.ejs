<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[60vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80" 
             alt="Luxury Office" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-r from-lux-midnight via-lux-midnight/80 to-transparent dark:from-black dark:via-black/90 dark:to-transparent"></div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/10 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
        <div class="max-w-3xl">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
                OUR HERITAGE
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
                Architecting <br/>
                <span class="text-emerald-400">Excellence</span>
            </h1>
            
            <p class="text-lg md:text-xl text-white/70 max-w-2xl leading-relaxed">
                At DeepRealties, we don't just facilitate transactions; we build legacies. Founded on the principles of absolute transparency and elite service.
            </p>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="py-24 bg-white dark:bg-lux-midnight relative overflow-hidden">
    <!-- Subtle Pattern -->
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.03] dark:opacity-[0.05]"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
            <div>
                <h2 class="text-4xl lg:text-5xl font-display font-bold text-gray-900 dark:text-white mb-8 leading-tight">
                    Defined by <br/><span class="text-emerald-500 font-serif italic">Integrity</span>
                </h2>
                <p class="text-lg text-gray-600 dark:text-gray-400 mb-12 leading-relaxed">
                    Our journey began with a simple observation: real estate needs a human touch backed by industrial-grade verification. Today, we stand as a beacon of trust in the central Indian market.
                </p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-4">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white">Radical Honesty</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400">No hidden clauses, no gray areas. Every square inch of information is verified and visible.</p>
                    </div>
                    <div class="space-y-4">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        </div>
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white">Direct Velocity</h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400">Streamlined processes that respect your time, ensuring closures happen with unmatched speed.</p>
                    </div>
                </div>
            </div>
            
            <div class="relative">
                <div class="absolute -top-10 -right-10 w-64 h-64 bg-emerald-500/10 rounded-full blur-[100px]"></div>
                <div class="glass-panel p-2 rounded-[3.5rem] overflow-hidden border-gray-100 dark:border-white/10">
                    <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80" 
                         class="w-full h-full object-cover rounded-[3rem]">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Founder Section -->
<section class="py-24 bg-gray-50 dark:bg-black/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="glass-panel rounded-[4rem] overflow-hidden border-white/20 bg-white dark:bg-lux-midnight">
            <div class="flex flex-col lg:flex-row">
                <div class="lg:w-1/2 relative h-[500px] lg:h-auto overflow-hidden">
                    <img src="/images/founder_new.jpg" 
                         alt="Deepak Rathore" 
                         class="w-full h-full object-cover transition-all duration-1000">
                    <div class="absolute inset-0 bg-gradient-to-t from-lux-midnight/80 to-transparent lg:hidden"></div>
                </div>
                <div class="lg:w-1/2 p-12 lg:p-20 flex flex-col justify-center">
                    <span class="text-emerald-500 font-bold text-xs uppercase tracking-[0.3em] mb-4">The Visionary</span>
                    <h2 class="text-4xl md:text-5xl font-display font-bold text-gray-900 dark:text-white mb-8">Deepak Rathore</h2>
                    <p class="text-lg text-gray-500 dark:text-gray-400 mb-10 italic font-serif leading-relaxed">
                        "Real estate is not about brick and mortar; it's about the security of a family's future. My goal was to create a platform where every Indian could invest with absolute peace of mind."
                    </p>
                    <div class="flex items-center space-x-6">
                        <div class="flex flex-col">
                            <span class="text-2xl font-bold text-gray-900 dark:text-white">Founder</span>
                            <span class="text-xs text-gray-400 uppercase tracking-widest mt-1">Deep Realties</span>
                        </div>
                        <div class="h-10 w-px bg-gray-200 dark:bg-white/10"></div>
                        <div class="flex flex-col">
                            <span class="text-2xl font-bold text-emerald-500">500+</span>
                            <span class="text-xs text-gray-400 uppercase tracking-widest mt-1">Acres Delivered</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Final CTA -->
<section class="py-24 relative overflow-hidden bg-lux-midnight">
    <!-- Gradient Background -->
    <div class="absolute inset-0 bg-gradient-to-tr from-black via-lux-midnight to-emerald-900/20"></div>
    <div class="absolute top-0 left-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>

    <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
        <h2 class="text-4xl md:text-6xl font-display font-bold text-white mb-8 leading-tight">
            Begin Your Legacy <br/>
            <span class="text-emerald-400">With Us</span>
        </h2>
        <p class="text-xl text-white/50 mb-12 max-w-2xl mx-auto">
            Whether you are acquiring an estate or liquidating an asset, our elite consultants are ready to assist.
        </p>
        <div class="flex flex-wrap justify-center gap-6">
            <a href="/properties" class="px-10 py-5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-2xl font-bold text-lg transition-all shadow-2xl shadow-emerald-500/20">
                Explore Properties
            </a>
            <a href="/contact" class="px-10 py-5 bg-white/5 hover:bg-white/10 text-white border border-white/10 rounded-2xl font-bold text-lg transition-all">
                Speak to an Expert
            </a>
        </div>
    </div>
</section>
` }) %>
