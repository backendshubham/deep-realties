<%- include('../layouts/main', { content: `
<!-- Portfolio Command Center -->
<div class="min-h-screen relative py-32 px-4 sm:px-6 lg:px-8 overflow-hidden bg-white dark:bg-lux-midnight transition-colors">
    <!-- Background Decor -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-emerald-500/5 blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-1/3 h-full bg-emerald-900/5 blur-[120px] pointer-events-none"></div>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
        <!-- Header Section -->
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-20 animate-[fadeInUp_0.6s_ease]">
            <div>
                <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-[10px] font-bold uppercase tracking-[0.4em] mb-4 backdrop-blur-md">
                    GENESIS PORTFOLIO
                </span>
                <h1 class="text-4xl md:text-6xl font-display font-bold text-gray-900 dark:text-white tracking-tight">
                    Welcome, <span id="userName" class="text-emerald-500">Curator</span>
                </h1>
                <p class="text-gray-500 dark:text-gray-400 text-sm font-medium mt-2 max-w-lg">
                    Monitoring your high-value assets and direct market engagements in real-time.
                </p>
            </div>
            
            <div class="flex items-center gap-4">
                <a href="/sell" class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-xs uppercase tracking-widest rounded-2xl shadow-xl shadow-emerald-500/20 transition-all active:scale-[0.98]">
                    Acquire New Asset
                </a>
            </div>
        </header>

        <!-- Dynamic Statistics -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
            <div class="glass-panel p-10 rounded-[3rem] border-gray-100 dark:border-white/10 hover:border-emerald-500/30 transition-all group overflow-hidden relative">
                <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-colors"></div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-8">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 font-display">Active Inventory</p>
                <p id="propertyCount" class="text-5xl font-display font-bold text-gray-900 dark:text-white">——</p>
            </div>

            <div class="glass-panel p-10 rounded-[3rem] border-gray-100 dark:border-white/10 hover:border-emerald-500/30 transition-all group overflow-hidden relative">
                <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-colors"></div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-8">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                </div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 font-display">Market Enquiries</p>
                <p id="enquiryCount" class="text-5xl font-display font-bold text-gray-900 dark:text-white">——</p>
            </div>

            <div class="glass-panel p-10 rounded-[3rem] border-gray-100 dark:border-white/10 hover:border-emerald-500/30 transition-all group overflow-hidden relative">
                <div class="absolute -right-8 -top-8 w-24 h-24 bg-emerald-500/10 rounded-full blur-2xl group-hover:bg-emerald-500/20 transition-colors"></div>
                <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 mb-8">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 font-display">Interest Velocity</p>
                <p id="interestCount" class="text-5xl font-display font-bold text-gray-900 dark:text-white">——</p>
            </div>
        </div>

        <!-- Main Dashboard View -->
        <div class="grid lg:grid-cols-3 gap-16">
            <!-- Left: Portfolio List -->
            <div class="lg:col-span-2 space-y-12">
                <div class="flex items-center justify-between px-2">
                    <h2 class="text-xs font-bold text-gray-400 uppercase tracking-[0.4em]">Recent Curations</h2>
                    <a href="/my-properties" class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest hover:text-emerald-400 transition-colors">View Library</a>
                </div>

                <div id="propertiesList" class="space-y-6">
                    <!-- Loading Placeholder -->
                    <div class="animate-pulse space-y-6">
                        <div class="h-32 bg-gray-100 dark:bg-white/5 rounded-[2.5rem]"></div>
                        <div class="h-32 bg-gray-100 dark:bg-white/5 rounded-[2.5rem]"></div>
                    </div>
                </div>
            </div>

            <!-- Right: Interactions & Activity -->
            <div class="space-y-12">
                <div class="px-2">
                    <h2 class="text-xs font-bold text-gray-400 uppercase tracking-[0.4em]">Concierge Activity</h2>
                </div>
                
                <div class="glass-panel p-10 rounded-[3rem] border-gray-100 dark:border-white/10 bg-white dark:bg-gray-900/40">
                    <div id="activityFeed" class="space-y-8">
                        <p class="text-center text-sm text-gray-500 py-10 italic">Awaiting new engagements...</p>
                    </div>
                </div>
                
                <div class="p-10 rounded-[3rem] bg-emerald-600 text-white relative overflow-hidden group shadow-2xl shadow-emerald-500/30">
                    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000"></div>
                    <h3 class="text-2xl font-display font-bold mb-4 relative z-10">Exclusive Access</h3>
                    <p class="text-sm text-white/80 mb-8 relative z-10">Premium members receive direct alerts for pre-launch estates.</p>
                    <button class="px-6 py-3 bg-white text-emerald-600 font-bold text-[10px] uppercase tracking-widest rounded-xl relative z-10 transition-all hover:shadow-lg">Upgrade Tier</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function loadDashboard() {
        const token = localStorage.getItem('token');
        if (!token) return window.location.href = '/login';

        try {
            const userRes = await fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } });
            if (!userRes.ok) throw new Error();
            const userData = await userRes.json();
            if (userData.user.role === 'admin') return window.location.href = '/admin/dashboard';
            
            document.getElementById('userName').textContent = userData.user.full_name;

            // Load Data
            const [propRes, sentRes, recvRes] = await Promise.all([
                fetch('/api/properties/my-properties/list', { headers: { 'Authorization': 'Bearer ' + token } }),
                fetch('/api/enquiries/sent', { headers: { 'Authorization': 'Bearer ' + token } }),
                fetch('/api/enquiries/received', { headers: { 'Authorization': 'Bearer ' + token } })
            ]);

            const [props, sent, recv] = await Promise.all([propRes.json(), sentRes.json(), recvRes.json()]);

            // Stats
            document.getElementById('propertyCount').textContent = props.properties?.length || 0;
            document.getElementById('enquiryCount').textContent = sent.enquiries?.length || 0;
            document.getElementById('interestCount').textContent = recv.enquiries?.length || 0;

            // List
            const list = document.getElementById('propertiesList');
            const pShow = (props.properties || []).slice(0, 4);
            
            if (pShow.length > 0) {
                list.innerHTML = pShow.map((p, index) => \\\`
                    <div onclick="window.location.href='/properties/\\\${p.id}'" class="group glass-panel p-6 sm:p-8 rounded-[2.5rem] border-gray-100 dark:border-white/10 flex flex-col sm:flex-row items-center gap-8 hover:border-emerald-500/30 transition-all cursor-pointer animate-[fadeInUp_\\\${0.4 + (index*0.1)}s_ease-out] bg-white dark:bg-lux-midnight shadow-lg">
                        <div class="w-full sm:w-32 h-32 rounded-3xl overflow-hidden shadow-inner flex-shrink-0 bg-gray-100">
                            <img src="\\\${p.images && p.images[0] || 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80'}" 
                                 class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700">
                        </div>
                        <div class="flex-1 text-center sm:text-left">
                            <div class="flex flex-wrap justify-center sm:justify-start items-center gap-2 mb-3">
                                <span class="px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 text-[9px] font-bold uppercase tracking-widest rounded-full">\\\${p.property_type.toUpperCase()}</span>
                                <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest italic">\\\${p.status.toUpperCase()}</span>
                            </div>
                            <h3 class="text-2xl font-display font-bold text-gray-900 dark:text-white group-hover:text-emerald-500 transition-colors">₹\\\${p.price.toLocaleString()}</h3>
                            <p class="text-xs text-gray-500 dark:text-gray-400 font-medium">\\\${p.locality || 'Indore'}, \\\${p.city}</p>
                        </div>
                        <div class="w-12 h-12 rounded-full border border-gray-100 dark:border-white/10 flex items-center justify-center text-gray-400 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </div>
                    </div>
                \\\`).join('');
            } else {
                list.innerHTML = \\\`
                    <div class="py-20 text-center glass-panel rounded-[3rem] border-dashed border-gray-200 dark:border-white/10">
                        <p class="text-gray-500 dark:text-gray-400 text-sm italic mb-8">No curations identified in your portfolio.</p>
                        <a href="/sell" class="px-8 py-3 bg-emerald-600 text-white font-bold rounded-xl text-[10px] uppercase tracking-widest">Start First Listing</a>
                    </div>
                \\\`;
            }

            // Feed
            const feed = document.getElementById('activityFeed');
            const allEnq = [...(sent.enquiries || []), ...(recv.enquiries || [])].sort((a,b) => new Date(b.created_at) - new Date(a.created_at)).slice(0, 5);
            
            if (allEnq.length > 0) {
                feed.innerHTML = allEnq.map(e => \\\`
                    <div class="flex items-start gap-5 group">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 mt-2 flex-shrink-0"></div>
                        <div>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">\\\${new Date(e.created_at).toLocaleDateString()}</p>
                            <p class="text-sm font-bold text-gray-900 dark:text-white group-hover:text-emerald-500 transition-colors">Engagement on Ref: \\\${e.property_id.substring(0,8).toUpperCase()}</p>
                            <p class="text-[10px] text-gray-500 leading-relaxed italic">Direct communication established via DeepRealties Gateway.</p>
                        </div>
                    </div>
                \\\`).join('');
            }

        } catch (e) {
            console.error(e);
            window.location.href = '/login';
        }
    }

    document.addEventListener('DOMContentLoaded', loadDashboard);
</script>
` }) %>
