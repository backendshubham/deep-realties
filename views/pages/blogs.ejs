<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[40vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0 bg-lux-midnight dark:bg-black">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-lux-midnight/50 via-lux-midnight to-lux-midnight dark:from-black/50 dark:via-black dark:to-black"></div>
    </div>

    <!-- Decorative Glows -->
    <div class="absolute top-0 left-1/4 w-1/2 h-full bg-emerald-500/5 blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full text-center">
        <div class="max-w-3xl mx-auto">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-bold uppercase tracking-[0.3em] mb-6 backdrop-blur-md">
                THE DEEP JOURNAL
            </span>
            
            <h1 class="text-4xl md:text-6xl font-display font-bold text-white mb-6 leading-tight">
                Insights & <span class="text-emerald-400 font-serif italic">Expertise</span>
            </h1>
            
            <p class="text-lg text-white/60 max-w-2xl mx-auto leading-relaxed">
                Stay ahead of the curve with our curated editorial on real estate trends, luxury living, and strategic investment deep-dives.
            </p>
        </div>
    </div>
</section>

<!-- Journal Grid -->
<section class="py-24 bg-white dark:bg-lux-midnight min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Featured Tag Placeholder -->
        <div class="flex items-center justify-between mb-12 border-b border-gray-100 dark:border-white/5 pb-6">
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Recent Publications</h2>
            <div class="flex space-x-6 text-[10px] font-bold uppercase tracking-widest text-emerald-500">
                <a href="#" class="hover:text-emerald-400 transition-colors">Market Trends</a>
                <a href="#" class="text-gray-400 hover:text-white transition-colors">Luxury Guides</a>
                <a href="#" class="text-gray-400 hover:text-white transition-colors">Investment</a>
            </div>
        </div>

        <div id="blogsLoading" class="text-center py-40">
            <div class="inline-loader-spinner mx-auto mb-4 border-t-emerald-500"></div>
            <p class="text-gray-400 font-medium font-display uppercase tracking-widest text-[10px]">Assembling insights...</p>
        </div>

        <div id="blogsEmpty" class="hidden text-center py-40 glass-panel rounded-[2rem]">
            <p class="text-gray-500 dark:text-gray-400">Our editors are currently drafting new insights. Please visit us again shortly.</p>
        </div>

        <div id="blogsGrid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <!-- Dynamically Loaded -->
        </div>
    </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const gridEl = document.getElementById('blogsGrid');
    const loadingEl = document.getElementById('blogsLoading');
    const emptyEl = document.getElementById('blogsEmpty');

    async function loadBlogs() {
      try {
        const res = await fetch('/api/blogs');
        const data = await res.json();
        const blogs = data.blogs || [];

        loadingEl.classList.add('hidden');

        if (!blogs.length) {
          emptyEl.classList.remove('hidden');
          return;
        }

        gridEl.classList.remove('hidden');
        gridEl.innerHTML = blogs.map(b => {
          const date = b.published_at || b.created_at;
          const displayDate = date ? new Date(date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
          }) : 'RECENTLY PUBLISHED';

          const excerpt = b.excerpt || (b.content ? b.content.substring(0, 120) + '...' : '');

          return \`
            <article class="group flex flex-col h-full bg-gray-50 dark:bg-white/5 rounded-[2.5rem] p-8 border border-gray-100 dark:border-white/5 hover:border-emerald-500/30 transition-all duration-700">
                <div class="mb-8 overflow-hidden rounded-[1.5rem] aspect-video relative">
                    <img src="\${b.featured_image_url || 'https://images.unsplash.com/photo-1434626881859-194d67b2b86f?auto=format&fit=crop&q=80'}" 
                         class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-1000">
                    <div class="absolute top-4 left-4 bg-emerald-500 text-white text-[9px] font-bold px-3 py-1.5 rounded-full uppercase tracking-tighter">
                        Perspective
                    </div>
                </div>
                
                <div class="flex-1 flex flex-col">
                    <div class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest mb-4">
                        \${displayDate}
                    </div>
                    
                    <h2 class="text-2xl font-display font-bold text-gray-900 dark:text-white mb-4 line-clamp-2 leading-tight group-hover:text-emerald-500 transition-colors">
                        <a href="/blogs/\${encodeURIComponent(b.slug)}">\${b.title}</a>
                    </h2>
                    
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-8 line-clamp-3 leading-relaxed">
                        \${excerpt}
                    </p>
                    
                    <div class="mt-auto pt-6 border-t border-gray-200 dark:border-white/5 flex items-center justify-between">
                        <span class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">5 Min Read</span>
                        <a href="/blogs/\${encodeURIComponent(b.slug)}" class="inline-flex items-center text-emerald-500 font-bold text-sm hover:text-emerald-400 transition-colors">
                            Read Full Piece
                            <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </a>
                    </div>
                </div>
            </article>
          \`;
        }).join('');
      } catch (err) {
        console.error(err);
        loadingEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
      }
    }

    loadBlogs();
  });
</script>
` }) %>
