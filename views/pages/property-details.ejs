<%- include('../layouts/main', { content: `
<!-- Hero / Gallery Section -->
<section class="relative pt-32 pb-12 overflow-hidden bg-white dark:bg-lux-midnight transition-colors">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumbs -->
        <nav class="flex mb-8 text-[10px] font-bold uppercase tracking-widest text-gray-400">
            <a href="/" class="hover:text-emerald-500 transition-colors">Home</a>
            <span class="mx-2">/</span>
            <a href="/properties" class="hover:text-emerald-500 transition-colors">Properties</a>
            <span class="mx-2">/</span>
            <span id="breadcrumbTitle" class="text-emerald-500 italic">Property Details</span>
        </nav>

        <div id="propertyGallery" class="relative group">
            <!-- Loading Grid -->
            <div id="galleryLoader" class="aspect-[21/9] w-full bg-gray-100 dark:bg-white/5 animate-pulse rounded-[3rem] flex items-center justify-center">
                <div class="inline-loader-spinner border-t-emerald-500"></div>
            </div>
            
            <!-- Dynamic Gallery -->
            <div id="galleryContainer" class="hidden grid grid-cols-4 grid-rows-2 gap-4 aspect-[21/9]">
                <div id="mainImage" class="col-span-2 row-span-2 relative overflow-hidden rounded-l-[3rem]">
                    <img src="" class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-1000 cursor-pointer" onclick="openLightbox(0)">
                </div>
                <div id="subImage1" class="col-span-1 row-span-1 overflow-hidden">
                    <img src="" class="w-full h-full object-cover transform hover:scale-110 transition-transform duration-1000 cursor-pointer" onclick="openLightbox(1)">
                </div>
                <div id="subImage2" class="col-span-1 row-span-1 overflow-hidden rounded-tr-[3rem]">
                    <img src="" class="w-full h-full object-cover transform hover:scale-110 transition-transform duration-1000 cursor-pointer" onclick="openLightbox(2)">
                </div>
                <div id="subImage3" class="col-span-1 row-span-1 overflow-hidden">
                    <img src="" class="w-full h-full object-cover transform hover:scale-110 transition-transform duration-1000 cursor-pointer" onclick="openLightbox(3)">
                </div>
                <div id="subImage4" class="col-span-1 row-span-1 relative overflow-hidden rounded-br-[3rem]">
                    <img src="" class="w-full h-full object-cover transform hover:scale-110 transition-transform duration-1000 cursor-pointer" onclick="openLightbox(4)">
                    <div id="morePhotos" class="hidden absolute inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center cursor-pointer hover:bg-black/40 transition-all" onclick="openLightbox(4)">
                        <span class="text-white font-bold text-xl">+<span id="remainingPhotos">5</span> Photos</span>
                    </div>
                </div>
            </div>

            <!-- Badges -->
            <div id="galleryBadges" class="absolute top-8 left-8 flex flex-col gap-3 z-10">
                <span id="propTypeBadge" class="px-5 py-2 bg-emerald-600 text-white text-[10px] font-bold uppercase tracking-widest rounded-full shadow-lg backdrop-blur-md">
                    PENDING LOAD
                </span>
                <span id="propIdBadge" class="px-5 py-2 bg-white/10 text-white text-[10px] font-bold uppercase tracking-widest rounded-full shadow-lg backdrop-blur-md border border-white/20">
                    ID: ——
                </span>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="pb-24 bg-white dark:bg-lux-midnight">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-16">
            <!-- Left: Primary Info -->
            <div class="lg:col-span-2">
                <div id="primaryInfo" class="mb-12">
                    <h1 id="propTitle" class="text-4xl md:text-5xl lg:text-7xl font-display font-bold text-gray-900 dark:text-white mb-6 leading-tight">
                        Scanning Property...
                    </h1>
                    <div class="flex items-center text-emerald-500 font-bold mb-8 uppercase tracking-[0.2em] text-sm">
                        <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"></path></svg>
                        <span id="propLocation">——</span>
                    </div>
                    
                    <div class="flex flex-wrap gap-12 items-center py-10 border-y border-gray-100 dark:border-white/10">
                        <div class="flex items-center gap-4">
                            <div class="text-emerald-500">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Property Type</p>
                                <p id="propTypeDisplay" class="text-lg font-bold text-gray-900 dark:text-white capitalize">——</p>
                            </div>
                        </div>
                        <div id="bedroomStat" class="hidden flex items-center gap-4">
                            <div class="text-emerald-500">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Bedrooms</p>
                                <p id="propBedrooms" class="text-lg font-bold text-gray-900 dark:text-white">——</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="text-emerald-500">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path></svg>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Area Size</p>
                                <p id="propArea" class="text-lg font-bold text-gray-900 dark:text-white">—— Sq.Ft</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="prose prose-lg dark:prose-invert max-w-none mb-16">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 uppercase tracking-widest text-[10px]">The Narrative</h3>
                    <div id="propDescription" class="text-gray-600 dark:text-gray-400 leading-[1.8] text-lg lg:text-xl font-light">
                        Loading detailed property description...
                    </div>
                </div>

                <div id="amenitiesSection" class="hidden mb-16">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 uppercase tracking-widest text-[10px]">Amenities & Features</h3>
                    <div id="amenitiesGrid" class="grid grid-cols-2 md:grid-cols-3 gap-6">
                        <!-- Dynamic -->
                    </div>
                </div>
            </div>

            <!-- Right: Sidebar Pricing / Contact -->
            <div class="lg:sticky lg:top-32 h-fit">
                <div class="glass-panel p-10 rounded-[3rem] border-white/10 shadow-2xl relative overflow-hidden">
                    <div class="absolute -top-24 -right-24 w-48 h-48 bg-emerald-500/5 blur-3xl"></div>
                    
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Investment Capital</p>
                    <div id="propPrice" class="text-4xl md:text-5xl font-display font-bold text-emerald-500 mb-10 leading-none">
                        ₹——
                    </div>

                    <div class="space-y-4 mb-10">
                        <div class="p-6 bg-gray-50 dark:bg-white/5 rounded-2xl border border-gray-100 dark:border-white/10">
                            <p id="ownerMessage" class="text-sm font-medium text-gray-600 dark:text-gray-400 text-center">
                                Direct acquisition verified by DeepRealties Curators.
                            </p>
                        </div>
                    </div>

                    <div id="actionArea">
                        <button onclick="showContactDetails()" class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-lg rounded-2xl transition-all shadow-xl shadow-emerald-500/20 group uppercase tracking-widest">
                            Inquire Now
                        </button>
                    </div>

                    <div class="mt-8 pt-8 border-t border-gray-100 dark:border-white/10 text-center">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Concierge Support</p>
                        <div class="flex justify-center space-x-6">
                            <a href="tel:+918305551215" class="w-12 h-12 rounded-full border border-gray-100 dark:border-white/10 flex items-center justify-center text-emerald-500 hover:bg-emerald-500 hover:text-white transition-all">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 005.505 5.505l.773-1.548a1 1 0 011.06-.539l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path></svg>
                            </a>
                            <a href="https://wa.me/918305551215" class="w-12 h-12 rounded-full border border-gray-100 dark:border-white/10 flex items-center justify-center text-emerald-500 hover:bg-emerald-500 hover:text-white transition-all">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.631 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    async function loadPropertyDetails() {
        const pathParts = window.location.pathname.split('/');
        const propertyId = pathParts[pathParts.length - 1];
        
        try {
            const response = await fetch('/api/properties/' + propertyId);
            if (!response.ok) throw new Error('Property not found');
            const data = await response.json();
            const p = data.property;
            
            if (!p) throw new Error('Property not found');
            window.currentPropertyData = p;

            // Update Text Elements
            document.getElementById('breadcrumbTitle').textContent = p.title;
            document.getElementById('propTitle').textContent = p.title;
            document.getElementById('propLocation').textContent = \\\`\\\${p.locality}, \\\${p.city}\\\`;
            document.getElementById('propPrice').textContent = \\\`₹\\\${p.price.toLocaleString()}\\\`;
            document.getElementById('propTypeBadge').textContent = p.property_type.toUpperCase();
            document.getElementById('propTypeDisplay').textContent = p.property_type;
            document.getElementById('propIdBadge').textContent = \\\`ID: \\\${p.id.substring(0, 8).toUpperCase()}\\\`;
            document.getElementById('propArea').textContent = \\\`\\\${p.area_sqft} Sq.Ft\\\`;
            document.getElementById('propDescription').textContent = p.description || 'A masterpiece of architectural design located in Indore\\'s most prestigious postcode.';

            if (p.bedrooms) {
                document.getElementById('bedroomStat').classList.remove('hidden');
                document.getElementById('propBedrooms').textContent = \\\`\\\${p.bedrooms} Premium BDS\\\`;
            }

            // Image Gallery Logic
            const images = (p.images && p.images.length > 0) ? p.images : ['https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80'];
            const galleryLoader = document.getElementById('galleryLoader');
            const galleryContainer = document.getElementById('galleryContainer');
            
            galleryLoader.classList.add('hidden');
            galleryContainer.classList.remove('hidden');

            const imgSlots = ['mainImage', 'subImage1', 'subImage2', 'subImage3', 'subImage4'];
            imgSlots.forEach((slot, i) => {
                const el = document.getElementById(slot);
                const img = el.querySelector('img');
                if (images[i]) {
                    img.src = images[i];
                    el.classList.remove('hidden');
                } else {
                    el.classList.add('hidden');
                }
            });

            if (images.length > 5) {
                const more = document.getElementById('morePhotos');
                const remaining = document.getElementById('remainingPhotos');
                more.classList.remove('hidden');
                remaining.textContent = images.length - 4;
            }

            // Ownership Logic
            const token = localStorage.getItem('token');
            if (token) {
                const userRes = await fetch('/api/auth/me', { headers: { 'Authorization': 'Bearer ' + token } });
                if (userRes.ok) {
                    const userData = await userRes.json();
                    if (userData.user && userData.user.id === p.seller_id) {
                        document.getElementById('ownerMessage').textContent = 'You are the registered curator of this listing.';
                        const actionBtn = document.querySelector('#actionArea button');
                        actionBtn.textContent = 'Manage Your Listing';
                        actionBtn.onclick = () => window.location.href = '/my-properties';
                        actionBtn.className = "w-full py-5 bg-white/10 text-emerald-500 font-bold text-lg rounded-2xl transition-all border border-emerald-500/50 hover:bg-emerald-500 hover:text-white uppercase tracking-widest";
                    }
                }
            }

        } catch (e) {
            console.error(e);
            document.body.innerHTML = \\\`
                <div class="min-h-screen flex items-center justify-center bg-lux-midnight text-white text-center p-8">
                    <div>
                        <h1 class="text-6xl font-display font-bold mb-4">404</h1>
                        <p class="text-xl text-gray-400 mb-8">This estate has been moved, acquired, or never existed.</p>
                        <a href="/properties" class="px-8 py-3 bg-emerald-600 text-white rounded-xl font-bold">Return to Library</a>
                    </div>
                </div>
            \\\`;
        }
    }

    function showContactDetails() {
        const p = window.currentPropertyData;
        const content = \\\`
            <div class="space-y-8 p-4">
                <div class="flex items-center space-x-6 p-6 bg-gray-50 dark:bg-white/5 rounded-3xl border border-gray-100 dark:border-white/10">
                    <div class="w-16 h-16 rounded-full bg-emerald-500 flex items-center justify-center text-white text-2xl font-bold">D</div>
                    <div>
                        <h4 class="text-xl font-bold text-gray-900 dark:text-white">DeepRealties Concierge</h4>
                        <p class="text-xs text-emerald-500 font-bold uppercase tracking-widest">Certified Curator</p>
                    </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-center">
                    <a href="tel:+918305551215" class="p-6 bg-emerald-600 text-white rounded-3xl hover:bg-emerald-500 transition-all font-bold">
                        <svg class="w-6 h-6 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        Call
                    </a>
                    <a href="mailto:deeprealties@gmail.com" class="p-6 bg-white/5 text-emerald-500 border border-emerald-500/30 rounded-3xl hover:bg-emerald-500 hover:text-white transition-all font-bold">
                        <svg class="w-6 h-6 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        Email
                    </a>
                </div>

                <div class="text-center">
                    <p class="text-[10px] text-gray-500 dark:text-gray-400 uppercase tracking-widest">Property Assignment Reference</p>
                    <p class="text-sm font-mono text-emerald-500 mt-1">\\\${p.id}</p>
                </div>
            </div>
        \\\`;
        window.showModal && window.showModal('Assignment Curator', content);
    }

    document.addEventListener('DOMContentLoaded', loadPropertyDetails);
</script>
` }) %>
