<%- include('../layouts/main', { content: `
<!-- Hero Section -->
<section class="relative min-h-[50vh] flex items-center pt-32 pb-20 overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?auto=format&fit=crop&q=80" 
             alt="Luxury Rental" 
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-r from-lux-midnight via-lux-midnight/80 to-transparent dark:from-black dark:via-black/90 dark:to-transparent"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full text-left">
        <div class="max-w-3xl">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-sm font-medium mb-6 backdrop-blur-md">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse mr-2"></span>
                PREMIUM RENTALS & LEASING
            </span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white mb-6 leading-tight">
                Find Your Perfect <br/>
                <span class="text-emerald-400">Rental Home</span>
            </h1>
            
            <p class="text-lg md:text-xl text-white/70 mb-10 max-w-2xl leading-relaxed">
                Discover a curated collection of verified premium rentals, from modern apartments to independent villas.
            </p>
        </div>
    </div>
</section>

<!-- Stats & Trust Section (Rental Specific) -->
<section class="py-12 relative bg-white dark:bg-lux-midnight border-b border-gray-100 dark:border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="text-center">
                <div class="text-3xl font-bold text-emerald-500 mb-1">1,200+</div>
                <div class="text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400">Active Listings</div>
            </div>
            <div class="text-center border-l border-gray-100 dark:border-white/10">
                <div class="text-3xl font-bold text-emerald-500 mb-1">Verified</div>
                <div class="text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400">Properties Only</div>
            </div>
            <div class="text-center border-l border-gray-100 dark:border-white/10">
                <div class="text-3xl font-bold text-emerald-500 mb-1">Direct</div>
                <div class="text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400">Owner Access</div>
            </div>
            <div class="text-center border-l border-gray-100 dark:border-white/10">
                <div class="text-3xl font-bold text-emerald-500 mb-1">Expert</div>
                <div class="text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400">Leasing Support</div>
            </div>
        </div>
    </div>
</section>

<!-- Action Tabs -->
<section class="sticky top-20 z-30 bg-white/80 dark:bg-lux-midnight/80 backdrop-blur-xl border-b border-gray-100 dark:border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-center space-x-8">
            <button id="findTab" onclick="switchTab('find')" 
                    class="py-6 px-4 text-emerald-500 border-b-2 border-emerald-500 font-bold transition-all flex items-center space-x-2 group">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <span>Find Property</span>
            </button>
            <button id="listTab" onclick="switchTab('list')" 
                    class="py-6 px-4 text-gray-500 dark:text-gray-400 border-b-2 border-transparent hover:text-emerald-500 transition-all font-bold flex items-center space-x-2 group">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                <span>List Property</span>
            </button>
        </div>
    </div>
</section>

<!-- Find Section -->
<div id="findSection" class="py-16 bg-gray-50 dark:bg-black/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Advanced Search Filter Bar -->
        <div class="glass-panel p-6 rounded-3xl mb-12 shadow-2xl relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-emerald-500/5 blur-3xl"></div>
            <form id="searchForm" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-4 items-end">
                <div class="lg:col-span-1">
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">City</label>
                    <input type="text" id="searchCity" placeholder="City" 
                           class="w-full px-4 py-3 rounded-xl bg-white dark:bg-white/5 border border-gray-100 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Type</label>
                    <select id="searchPropertyType" class="w-full px-4 py-3 rounded-xl bg-white dark:bg-white/5 border border-gray-100 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all appearance-none">
                        <option value="">All Types</option>
                        <option value="flat">Flat</option>
                        <option value="house">House</option>
                        <option value="plot">Plot</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Furnishing</label>
                    <select id="searchFurnishing" class="w-full px-4 py-3 rounded-xl bg-white dark:bg-white/5 border border-gray-100 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all appearance-none">
                        <option value="">All</option>
                        <option value="furnished">Furnished</option>
                        <option value="semi-furnished">Semi</option>
                        <option value="unfurnished">Unfurnished</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Max Rent (₹)</label>
                    <input type="number" id="searchMaxRent" placeholder="Budget" 
                           class="w-full px-4 py-3 rounded-xl bg-white dark:bg-white/5 border border-gray-100 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase mb-2 tracking-widest pl-1">Bedrooms</label>
                    <input type="number" id="searchBedrooms" placeholder="BHK" 
                           class="w-full px-4 py-3 rounded-xl bg-white dark:bg-white/5 border border-gray-100 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                </div>
                <button type="button" onclick="searchRentals()" 
                        class="w-full py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-emerald-500/20 flex items-center justify-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6"></path></svg>
                    <span>Search</span>
                </button>
            </form>
        </div>

        <!-- Results Grid -->
        <div id="rentalsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Dynamically populated -->
        </div>

        <div id="loadingState" class="hidden text-center py-20">
            <div class="inline-block w-8 h-8 border-4 border-emerald-500/30 border-t-emerald-500 rounded-full animate-spin"></div>
            <p class="mt-4 text-gray-500 dark:text-gray-400 font-medium">Curating rental inventory...</p>
        </div>

        <div id="emptyState" class="hidden text-center py-24 glass-panel rounded-3xl">
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">No matching properties found</h3>
            <p class="text-gray-500 dark:text-gray-400">Try adjusting your filters or search criteria.</p>
        </div>
    </div>
</div>

<!-- List Section -->
<div id="listSection" class="hidden py-16 bg-gray-50 dark:bg-black/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Success Message -->
        <div id="successMessage" class="hidden glass-panel border-emerald-500/50 p-12 text-center rounded-3xl mb-12">
            <div class="w-20 h-20 bg-emerald-500 rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg shadow-emerald-500/20">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Property Listed!</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
                Your rental property has been submitted for review. Our team will verify the details and approve it within 24-48 hours.
            </p>
            <div class="flex justify-center space-x-4">
                <button onclick="switchTab('find')" class="px-8 py-3 bg-emerald-600 text-white rounded-xl hover:bg-emerald-700 transition-colors">
                    Browse Rentals
                </button>
                <button onclick="resetRentalForm()" class="px-8 py-3 bg-white/10 text-gray-900 dark:text-white rounded-xl hover:bg-white/20 transition-colors border border-gray-200 dark:border-white/10">
                    List Another
                </button>
            </div>
        </div>

        <div id="rentalFormContainer" class="glass-panel p-8 md:p-12 rounded-[2rem] border-white/10 shadow-2xl relative overflow-hidden">
            <h2 class="text-3xl font-display font-bold text-gray-900 dark:text-white mb-8">Property Details</h2>
            
            <form id="rentalForm" class="space-y-8">
                <!-- Property Type -->
                <div class="space-y-6">
                    <label class="block text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-widest">Select Property Type</label>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="flat" class="peer sr-only" checked>
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">Flat</span>
                            </div>
                        </label>
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="house" class="peer sr-only">
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">House</span>
                            </div>
                        </label>
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="plot" class="peer sr-only">
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">Plot</span>
                            </div>
                        </label>
                        <label class="relative cursor-pointer group">
                            <input type="radio" name="property_type" value="farmland" class="peer sr-only">
                            <div class="p-4 text-center rounded-2xl border-2 border-gray-100 dark:border-white/5 bg-white dark:bg-white/5 peer-checked:border-emerald-500 peer-checked:bg-emerald-500/5 transition-all group-hover:border-emerald-500/30">
                                <span class="block text-sm font-bold text-gray-700 dark:text-gray-300 peer-checked:text-emerald-500 capitalize">Farmland</span>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Basic Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Listing Title</label>
                        <input type="text" name="title" required placeholder="e.g. Spacious 3BHK Apartment for family"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>
                    
                    <div class="md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Description</label>
                        <textarea name="description" rows="4" required placeholder="Describe your property..."
                                  class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all"></textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Monthly Rent (₹)</label>
                        <input type="number" name="monthly_rent" required placeholder="e.g. 25000"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Security Deposit (₹)</label>
                        <input type="number" name="security_deposit" placeholder="e.g. 50000"
                               class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 focus:ring-0 transition-all">
                    </div>

                    <!-- Dynamic Fields -->
                    <div id="plotFields" class="hidden md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Length (ft)</label>
                            <input type="number" name="plot_length" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Width (ft)</label>
                            <input type="number" name="plot_width" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Total Area</label>
                            <input type="number" name="plot_total_area" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white">
                        </div>
                    </div>

                    <div id="otherPropertyFields" class="md:col-span-2 grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Bedrooms</label>
                            <input type="number" name="bedrooms" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Bathrooms</label>
                            <input type="number" name="bathrooms" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white">
                        </div>
                        <div id="areaFieldContainer">
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Area (Sq.Ft)</label>
                            <input type="number" name="area_sqft" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white">
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Furnishing</label>
                        <select name="furnishing" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all appearance-none">
                            <option value="">Select Furnishing</option>
                            <option value="furnished">Furnished</option>
                            <option value="semi-furnished">Semi-Furnished</option>
                            <option value="unfurnished">Unfurnished</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2 uppercase tracking-widest">Tenant Preferred</label>
                        <select name="tenant_type" class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500 transition-all appearance-none">
                            <option value="">Any</option>
                            <option value="family">Family</option>
                            <option value="bachelors">Bachelors</option>
                            <option value="company">Company</option>
                        </select>
                    </div>
                </div>

                <!-- Contact Info -->
                <div class="space-y-8 pt-8 border-t border-gray-100 dark:border-white/10">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white uppercase tracking-wider">Contact Information</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Full Name</label>
                            <input type="text" name="full_name" required class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Email</label>
                            <input type="email" name="email" required class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">Phone</label>
                            <input type="tel" name="phone" required class="w-full px-6 py-4 rounded-xl bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white focus:border-emerald-500">
                        </div>
                    </div>
                </div>

                <button type="submit" 
                        class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-lg rounded-2xl transition-all shadow-xl shadow-emerald-500/20 flex items-center justify-center group">
                    <span>List for Rent</span>
                    <svg class="w-6 h-6 ml-2 transform group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        const findSection = document.getElementById('findSection');
        const listSection = document.getElementById('listSection');
        const findTab = document.getElementById('findTab');
        const listTab = document.getElementById('listTab');
        
        if (tab === 'find') {
            findSection.classList.remove('hidden');
            listSection.classList.add('hidden');
            findTab.className = "py-6 px-4 text-emerald-500 border-b-2 border-emerald-500 font-bold transition-all flex items-center space-x-2 group";
            listTab.className = "py-6 px-4 text-gray-500 dark:text-gray-400 border-b-2 border-transparent hover:text-emerald-500 transition-all font-bold flex items-center space-x-2 group";
            loadRentals();
        } else {
            findSection.classList.add('hidden');
            listSection.classList.remove('hidden');
            listTab.className = "py-6 px-4 text-emerald-500 border-b-2 border-emerald-500 font-bold transition-all flex items-center space-x-2 group";
            findTab.className = "py-6 px-4 text-gray-500 dark:text-gray-400 border-b-2 border-transparent hover:text-emerald-500 transition-all font-bold flex items-center space-x-2 group";
        }
    }

    async function loadRentals(filters = {}) {
        const grid = document.getElementById('rentalsGrid');
        const loading = document.getElementById('loadingState');
        const empty = document.getElementById('emptyState');
        
        grid.innerHTML = '';
        grid.classList.add('hidden');
        loading.classList.remove('hidden');
        empty.classList.add('hidden');
        
        try {
            const params = new URLSearchParams(filters);
            const res = await fetch('/api/rentals?' + params.toString());
            const data = await res.json();
            
            loading.classList.add('hidden');
            
            if (data.rentals && data.rentals.length > 0) {
                grid.classList.remove('hidden');
                grid.innerHTML = data.rentals.map(rental => \\\`
                    <div class="glass-panel group rounded-3xl overflow-hidden hover:border-emerald-500/50 transition-all duration-500">
                        <div class="relative h-64 overflow-hidden">
                            <img src="\\\${rental.images && rental.images[0] || 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?auto=format&fit=crop&q=80'}" 
                                 class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-4 right-4 bg-emerald-600 text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-wider backdrop-blur-md">
                                FOR RENT
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="flex items-center text-emerald-500 text-sm font-bold mb-2 uppercase tracking-widest">
                                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20"><path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"></path></svg>
                                \\\${rental.locality}, \\\${rental.city}
                            </div>
                            <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4 line-clamp-1 group-hover:text-emerald-500 transition-colors">
                                \\\${rental.title}
                            </h3>
                            <div class="flex items-center justify-between pt-6 border-t border-gray-100 dark:border-white/10">
                                <div class="text-2xl font-bold text-emerald-500">
                                    ₹\\\${rental.monthly_rent.toLocaleString()}<span class="text-xs font-medium text-gray-400">/mo</span>
                                </div>
                                <a href="/rentals/\\\${rental.id}" class="px-5 py-2 bg-white/5 hover:bg-emerald-500 text-gray-900 dark:text-white hover:text-white rounded-xl text-sm font-bold transition-all border border-gray-200 dark:border-white/10">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                \\\`).join('');
            } else {
                empty.classList.remove('hidden');
            }
        } catch (e) {
            console.error(e);
            loading.classList.add('hidden');
            empty.classList.remove('hidden');
        }
    }

    function searchRentals() {
        const filters = {
            city: document.getElementById('searchCity').value,
            property_type: document.getElementById('searchPropertyType').value,
            furnishing: document.getElementById('searchFurnishing').value,
            max_rent: document.getElementById('searchMaxRent').value,
            bedrooms: document.getElementById('searchBedrooms').value
        };
        loadRentals(filters);
    }

    function toggleRentalPropertyFields() {
        const typeEl = document.querySelector('#rentalForm input[name="property_type"]:checked');
        if (!typeEl) return;
        const type = typeEl.value;
        const plotFields = document.getElementById('plotFields');
        const otherFields = document.getElementById('otherPropertyFields');
        const areaFieldContainer = document.getElementById('areaFieldContainer');

        if (type === 'plot') {
            plotFields.classList.remove('hidden');
            otherFields.classList.add('hidden');
            areaFieldContainer.classList.add('hidden');
        } else {
            plotFields.classList.add('hidden');
            otherFields.classList.remove('hidden');
            areaFieldContainer.classList.remove('hidden');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        loadRentals();
        const radios = document.querySelectorAll('#rentalForm input[name="property_type"]');
        radios.forEach(r => r.addEventListener('change', toggleRentalPropertyFields));
        toggleRentalPropertyFields();
    });

    function resetRentalForm() {
        document.getElementById('successMessage').classList.add('hidden');
        document.getElementById('rentalFormContainer').style.display = 'block';
        document.getElementById('rentalForm').reset();
        toggleRentalPropertyFields();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    document.getElementById('rentalForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        
        // Basic conversion
        if (data.monthly_rent) data.monthly_rent = parseFloat(data.monthly_rent);
        if (data.security_deposit) data.security_deposit = parseFloat(data.security_deposit);
        if (data.bedrooms) data.bedrooms = parseInt(data.bedrooms);
        if (data.bathrooms) data.bathrooms = parseInt(data.bathrooms);
        if (data.area_sqft) data.area_sqft = parseFloat(data.area_sqft);
        
        if (data.property_type === 'plot') {
            const l = parseFloat(formData.get('plot_length')) || 0;
            const w = parseFloat(formData.get('plot_width')) || 0;
            data.area_sqft = parseFloat(formData.get('plot_total_area')) || (l * w);
        }

        try {
            const token = localStorage.getItem('token');
            const res = await fetch('/api/rentals', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    ...(token && { 'Authorization': 'Bearer ' + token })
                },
                body: JSON.stringify(data)
            });
            
            if (res.ok) {
                document.getElementById('rentalFormContainer').style.display = 'none';
                document.getElementById('successMessage').classList.remove('hidden');
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                const error = await res.json();
                if (window.showError) window.showError(error.error || 'Submission failed');
                else alert(error.error || 'Submission failed');
            }
        } catch (e) {
            console.error(e);
            alert('An error occurred. Please try again.');
        }
    });
</script>
